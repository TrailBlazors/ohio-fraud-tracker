# =============================================================================
# Ohio Fraud Tracker - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Get your connection string from: https://neon.tech
# Use the "pooled" connection string for serverless/Railway
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/ohio-fraud-tracker?sslmode=require

# -----------------------------------------------------------------------------
# API Settings
# -----------------------------------------------------------------------------
# Enable SQL query logging (set to "true" for debugging)
SQL_ECHO=false

# -----------------------------------------------------------------------------
# Frontend Settings
# -----------------------------------------------------------------------------
# URL of the API server (Railway will give you this after deploying API)
# For local dev, leave empty to use http://localhost:8000
PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# External APIs (for data imports)
# -----------------------------------------------------------------------------
USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2
SBIR_BASE_URL=https://api.www.sbir.gov/public/api

# Rate limiting (requests per minute)
USASPENDING_RATE_LIMIT=120
SBIR_RATE_LIMIT=60

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# =============================================================================
# RAILWAY DEPLOYMENT
# =============================================================================
# Deploy as TWO services from this repo:
#
# 1. API Service:
#    - Root Directory: /api
#    - Set DATABASE_URL env var
#
# 2. Frontend Service:
#    - Root Directory: /frontend
#    - Set PUBLIC_API_URL to your API service URL (e.g., https://api-xxx.railway.app)
# =============================================================================
