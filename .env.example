# =============================================================================
# Ohio Fraud Tracker - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Turso - Production)
# -----------------------------------------------------------------------------
# Get these from your Turso dashboard: https://turso.tech/app
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# -----------------------------------------------------------------------------
# Database (Local Development)
# -----------------------------------------------------------------------------
# Leave TURSO_* variables empty to use local SQLite
# Database file will be created at: api/data/ohio_fraud_tracker.db

# -----------------------------------------------------------------------------
# API Settings
# -----------------------------------------------------------------------------
# Enable SQL query logging (set to "true" for debugging)
SQL_ECHO=false

# -----------------------------------------------------------------------------
# External APIs (for data imports)
# -----------------------------------------------------------------------------
USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend (Astro)
# -----------------------------------------------------------------------------
# Only needed if running frontend separately from API
# In production (Vercel monorepo), this should be empty
PUBLIC_API_URL=http://localhost:8000
