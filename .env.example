# Database connection
DATABASE_URL=postgresql://user:password@localhost:5432/ohio_fraud_tracker

# API Settings
USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2
SBIR_BASE_URL=https://api.www.sbir.gov/public/api

# Rate limiting (requests per minute)
USASPENDING_RATE_LIMIT=120
SBIR_RATE_LIMIT=60

# Logging
LOG_LEVEL=INFO

# Data directory for cached files
DATA_DIR=./data
