# =============================================================================
# Ohio Fraud Tracker - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Get your connection string from: https://neon.tech
# Use the "pooled" connection string for serverless environments
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/ohio-fraud-tracker?sslmode=require

# -----------------------------------------------------------------------------
# API Settings
# -----------------------------------------------------------------------------
# Enable SQL query logging (set to "true" for debugging)
SQL_ECHO=false

# -----------------------------------------------------------------------------
# External APIs (for data imports)
# -----------------------------------------------------------------------------
USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2
SBIR_BASE_URL=https://api.www.sbir.gov/public/api

# Rate limiting (requests per minute)
USASPENDING_RATE_LIMIT=120
SBIR_RATE_LIMIT=60

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend (Astro) - Local Development Only
# -----------------------------------------------------------------------------
# In production (Vercel), leave PUBLIC_API_URL empty - API is on same domain
# For local dev, this is set automatically to http://localhost:8000
PUBLIC_API_URL=

# =============================================================================
# VERCEL DEPLOYMENT
# =============================================================================
# Set these environment variables in Vercel Dashboard:
#
# Required:
#   DATABASE_URL = (your Neon pooled connection string)
#
# Optional:
#   SQL_ECHO = false
#   LOG_LEVEL = INFO
# =============================================================================
