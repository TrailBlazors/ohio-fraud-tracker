# API Configuration

# Database - leave empty for local SQLite, or set Turso credentials
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local SQLite path (used if Turso not configured)
DATABASE_URL=sqlite:///./data/ohio_fraud_tracker.db

# Debug
SQL_ECHO=false

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
