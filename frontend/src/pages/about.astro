---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="container">
    <div class="about-content">
      <h1>About This Project</h1>
      
      <section>
        <h2>Mission</h2>
        <p>
          Ohio Funding Tracker aggregates public data on federal grants, loans, and contracts 
          flowing into Ohio. Our goal is to make it easy for citizens, journalists, and 
          researchers to follow the money and understand how tax dollars are being spent.
        </p>
      </section>
      
      <section>
        <h2>What We Track</h2>
        <ul>
          <li><strong>Federal Grants</strong> - Block grants, formula grants, project grants, and cooperative agreements from all federal agencies</li>
          <li><strong>Federal Loans</strong> - Direct loans, guaranteed loans, SBA programs including PPP and EIDL</li>
          <li><strong>Contracts</strong> - Federal procurement contracts awarded to Ohio businesses</li>
          <li><strong>Business Status</strong> - Cross-referenced with Ohio Secretary of State filings to identify inactive businesses receiving funds</li>
        </ul>
      </section>
      
      <section>
        <h2>Data Sources</h2>
        <div class="sources-grid">
          <div class="source-card">
            <h3>USAspending.gov</h3>
            <p>Official source for federal spending data, including all grants, loans, and contracts.</p>
            <a href="https://usaspending.gov" target="_blank">Visit site →</a>
          </div>
          <div class="source-card">
            <h3>Ohio Checkbook</h3>
            <p>State-level spending transparency from the Ohio Treasurer's office.</p>
            <a href="https://checkbook.ohio.gov" target="_blank">Visit site →</a>
          </div>
          <div class="source-card">
            <h3>SBA.gov</h3>
            <p>Small Business Administration loan data including PPP and EIDL programs.</p>
            <a href="https://sba.gov" target="_blank">Visit site →</a>
          </div>
          <div class="source-card">
            <h3>Ohio Secretary of State</h3>
            <p>Business registration and filing status for Ohio entities.</p>
            <a href="https://businesssearch.ohiosos.gov" target="_blank">Visit site →</a>
          </div>
        </div>
      </section>
      
      <section>
        <h2>Inspiration</h2>
        <p>
          This project was inspired by the December 2024 Ohio Auditor report that found 
          <strong>39 of 60 companies</strong> receiving state tax incentives failed to meet 
          their job creation commitments - with most facing no consequences.
        </p>
        <p>
          We believe taxpayers deserve easy access to information about how their money is 
          being spent and whether recipients are delivering on their promises.
        </p>
      </section>
      
      <section>
        <h2>Disclaimer</h2>
        <p class="disclaimer">
          This site is for informational purposes only. While we strive for accuracy, 
          data may contain errors or be out of date. Always verify information with 
          official government sources before making decisions based on this data.
        </p>
      </section>
      
      <section>
        <h2>Open Source</h2>
        <p>
          This project is open source. Want to contribute or run your own instance?
        </p>
        <a href="https://github.com" class="btn btn-primary">View on GitHub</a>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .about-content {
    max-width: 800px;
    margin: 0 auto;
  }
  
  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
  }
  
  section {
    margin-bottom: 3rem;
  }
  
  h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
  }
  
  p {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  
  ul {
    margin: 0;
    padding-left: 1.5rem;
  }
  
  li {
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }
  
  li strong {
    color: var(--color-text);
  }
  
  .sources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }
  
  .source-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }
  
  .source-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
  }
  
  .source-card p {
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
  }
  
  .source-card a {
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .disclaimer {
    background: var(--color-bg-secondary);
    border-left: 4px solid var(--color-warning);
    padding: 1rem 1.5rem;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .btn-primary {
    background: var(--color-primary);
    color: white;
  }
  
  .btn-primary:hover {
    background: var(--color-primary-hover);
    text-decoration: none;
  }
</style>
