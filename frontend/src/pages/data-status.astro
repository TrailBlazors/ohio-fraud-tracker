---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout 
  title="Data Status - Ohio Fraud Tracker" 
  description="Check the status of data imports from USAspending.gov, SBA, and Ohio Checkbook. See when data was last updated and import statistics."
  keywords="Ohio Fraud Tracker data, USAspending data, SBA PPP data, Ohio Checkbook data, data freshness"
>
  <div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white">Data Status</h1>
        <p class="text-sm text-gray-600 dark:text-gray-400">Overview of imported data sources and database health</p>
      </div>
      <a href="/" class="text-primary-600 hover:text-primary-700 dark:text-primary-400 flex items-center gap-1 text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Dashboard
      </a>
    </div>

    <!-- Loading State -->
    <div id="loading-state" class="animate-pulse space-y-4">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        {[1,2,3,4].map(() => (
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-5">
            <div class="h-16 bg-gray-200 dark:bg-gray-700 rounded"></div>
          </div>
        ))}
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <div class="h-48 bg-gray-200 dark:bg-gray-700 rounded"></div>
      </div>
    </div>

    <!-- Error State (hidden) -->
    <div id="error-state" class="hidden bg-red-50 dark:bg-red-900/50 border border-red-200 dark:border-red-800 rounded-lg p-4">
      <p class="text-red-700 dark:text-red-300" id="error-message">Unable to connect to API</p>
    </div>

    <!-- Content (hidden until loaded) -->
    <div id="content" class="hidden space-y-6"></div>
  </div>
</DashboardLayout>

<script is:inline>
  const apiBase = window.location.hostname === 'localhost' ? 'http://localhost:8000' : '';
  
  function formatNumber(num) {
    return num.toLocaleString();
  }
  
  function formatCurrency(amount) {
    if (amount >= 1_000_000_000) return `$${(amount / 1_000_000_000).toFixed(2)}B`;
    if (amount >= 1_000_000) return `$${(amount / 1_000_000).toFixed(2)}M`;
    if (amount >= 1_000) return `$${(amount / 1_000).toFixed(1)}K`;
    return `$${amount.toFixed(0)}`;
  }
  
  function formatDate(dateStr) {
    if (!dateStr) return 'N/A';
    return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }
  
  function formatDateTime(dateStr) {
    if (!dateStr) return 'Never';
    return new Date(dateStr).toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }
  
  function getStatusColor(status) {
    switch (status) {
      case 'active': return 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300';
      case 'pending': return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300';
      case 'error': return 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300';
      default: return 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300';
    }
  }
  
  async function loadDataStatus() {
    try {
      const response = await fetch(`${apiBase}/api/stats/data-status`);
      if (!response.ok) throw new Error('Failed to load data status');
      const data = await response.json();
      
      document.getElementById('loading-state').classList.add('hidden');
      const content = document.getElementById('content');
      content.classList.remove('hidden');
      
      content.innerHTML = `
        <!-- Summary Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-3 sm:p-5">
            <div class="flex items-center">
              <div class="p-2 sm:p-3 rounded-full bg-blue-100 dark:bg-blue-900">
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <div class="ml-3 sm:ml-4">
                <p class="text-xs sm:text-sm font-medium text-gray-500 dark:text-gray-400">Total Awards</p>
                <p class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-white">${formatNumber(data.totals.total_awards)}</p>
              </div>
            </div>
          </div>
          
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-3 sm:p-5">
            <div class="flex items-center">
              <div class="p-2 sm:p-3 rounded-full bg-green-100 dark:bg-green-900">
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="ml-3 sm:ml-4">
                <p class="text-xs sm:text-sm font-medium text-gray-500 dark:text-gray-400">Total Amount</p>
                <p class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-white">${formatCurrency(data.totals.total_amount)}</p>
              </div>
            </div>
          </div>
          
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-3 sm:p-5">
            <div class="flex items-center">
              <div class="p-2 sm:p-3 rounded-full bg-purple-100 dark:bg-purple-900">
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
              </div>
              <div class="ml-3 sm:ml-4">
                <p class="text-xs sm:text-sm font-medium text-gray-500 dark:text-gray-400">Recipients</p>
                <p class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-white">${formatNumber(data.totals.total_recipients)}</p>
              </div>
            </div>
          </div>
          
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-3 sm:p-5">
            <div class="flex items-center">
              <div class="p-2 sm:p-3 rounded-full bg-orange-100 dark:bg-orange-900">
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
              </div>
              <div class="ml-3 sm:ml-4">
                <p class="text-xs sm:text-sm font-medium text-gray-500 dark:text-gray-400">With NAICS Code</p>
                <p class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-white">${formatNumber(data.totals.recipients_with_naics)}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Data Sources -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Data Sources</h2>
          </div>
          <div class="divide-y divide-gray-200 dark:divide-gray-700">
            ${data.sources.map(source => `
              <div class="p-6">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-3">
                      <h3 class="text-lg font-medium text-gray-900 dark:text-white">${source.name}</h3>
                      <span class="px-2.5 py-0.5 rounded-full text-xs font-medium ${getStatusColor(source.status)}">
                        ${source.status === 'active' ? 'Imported' : 'Pending'}
                      </span>
                    </div>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">${source.description}</p>
                    <a href="${source.url}" target="_blank" rel="noopener noreferrer" 
                       class="text-xs text-primary-600 hover:text-primary-700 dark:text-primary-400 flex items-center gap-1 mt-1">
                      ${source.url}
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"></path>
                        <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"></path>
                      </svg>
                    </a>
                  </div>
                  ${source.status === 'active' ? `
                    <div class="text-right">
                      <p class="text-2xl font-bold text-gray-900 dark:text-white">${formatNumber(source.record_count)}</p>
                      <p class="text-sm text-gray-500 dark:text-gray-400">records</p>
                      <p class="text-lg font-semibold text-green-600 dark:text-green-400 mt-1">${formatCurrency(source.total_amount)}</p>
                    </div>
                  ` : ''}
                </div>
                
                ${source.status === 'active' && source.date_range ? `
                  <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
                    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3">
                      <p class="text-gray-500 dark:text-gray-400">Date Range</p>
                      <p class="font-medium text-gray-900 dark:text-white">
                        ${formatDate(source.date_range.min)} - ${formatDate(source.date_range.max)}
                      </p>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3">
                      <p class="text-gray-500 dark:text-gray-400">First Import</p>
                      <p class="font-medium text-gray-900 dark:text-white">${formatDateTime(source.import_info?.first_import)}</p>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3">
                      <p class="text-gray-500 dark:text-gray-400">Last Updated</p>
                      <p class="font-medium text-gray-900 dark:text-white">${formatDateTime(source.import_info?.last_import)}</p>
                    </div>
                  </div>
                ` : ''}
                
                ${source.status === 'pending' ? `
                  <div class="mt-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-3">
                    <p class="text-sm text-yellow-700 dark:text-yellow-300">
                      This data source has not been imported yet.
                    </p>
                  </div>
                ` : ''}
              </div>
            `).join('')}
          </div>
        </div>

        <!-- Database Info -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Database Info</h2>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
              <div>
                <p class="text-gray-500 dark:text-gray-400">Total Agencies</p>
                <p class="text-lg font-semibold text-gray-900 dark:text-white">${formatNumber(data.totals.total_agencies)}</p>
              </div>
              <div>
                <p class="text-gray-500 dark:text-gray-400">NAICS Codes Loaded</p>
                <p class="text-lg font-semibold text-gray-900 dark:text-white">${formatNumber(data.totals.naics_codes_loaded)}</p>
              </div>
              <div>
                <p class="text-gray-500 dark:text-gray-400">Active Sources</p>
                <p class="text-lg font-semibold text-gray-900 dark:text-white">
                  ${data.sources.filter(s => s.status === 'active').length} / ${data.sources.length}
                </p>
              </div>
            </div>
          </div>
        </div>
      `;
    } catch (err) {
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-state').classList.remove('hidden');
      document.getElementById('error-message').textContent = err.message || 'Unable to connect to API';
    }
  }
  
  document.addEventListener('DOMContentLoaded', loadDataStatus);
</script>
