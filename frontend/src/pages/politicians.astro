---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import politiciansData from '../data/politicians.json';

// Count by chamber
const houseDems = politiciansData.legislators.filter(l => l.chamber === 'House' && l.party === 'D').length;
const houseReps = politiciansData.legislators.filter(l => l.chamber === 'House' && l.party === 'R').length;
const senateDems = politiciansData.legislators.filter(l => l.chamber === 'Senate' && l.party === 'D').length;
const senateReps = politiciansData.legislators.filter(l => l.chamber === 'Senate' && l.party === 'R').length;

function getPartyGradient(party: string): string {
  switch (party) {
    case 'D': return 'from-blue-600 to-blue-800';
    case 'R': return 'from-red-600 to-red-800';
    default: return 'from-gray-600 to-gray-800';
  }
}

function getPartyBorder(party: string): string {
  switch (party) {
    case 'D': return 'border-blue-500';
    case 'R': return 'border-red-500';
    default: return 'border-gray-500';
  }
}

function getPartyButton(party: string): string {
  switch (party) {
    case 'D': return 'bg-blue-600 hover:bg-blue-700';
    case 'R': return 'bg-red-600 hover:bg-red-700';
    default: return 'bg-gray-600 hover:bg-gray-700';
  }
}

function getPartyAvatar(party: string): string {
  switch (party) {
    case 'D': return 'bg-blue-400 text-blue-900';
    case 'R': return 'bg-red-400 text-red-900';
    default: return 'bg-gray-400 text-gray-900';
  }
}

function getChamberBadge(chamber: string): { icon: string; label: string; class: string } {
  switch (chamber) {
    case 'House': 
      return { icon: '🏛️', label: 'OH House', class: 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200' };
    case 'Senate': 
      return { icon: '⭐', label: 'OH Senate', class: 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200' };
    case 'US Senate': 
      return { icon: '🇺🇸', label: 'US Senate', class: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900 dark:text-emerald-200' };
    default: 
      return { icon: '📍', label: chamber, class: 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200' };
  }
}

function getInitials(name: string): string {
  return name
    .split(' ')
    .filter(n => !['Jr.', 'Jr', 'III', 'II', 'IV'].includes(n))
    .map(n => n[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();
}

// Pass data to client
const allLegislators = politiciansData.legislators;
---

<DashboardLayout 
  title="Ohio Politicians - Contact Your Representatives" 
  description="Contact Ohio state legislators and US Senators about government spending concerns. Find phone, email, and office information for all Ohio representatives."
  keywords="Ohio legislators, Ohio state representatives, Ohio senators contact, Ohio House members, Ohio government officials, contact Ohio politicians"
>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Ohio Politicians</h1>
    <p class="text-gray-500 dark:text-gray-400">Contact your representatives about federal funding concerns</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">Ohio House</div>
      <div class="text-2xl font-bold text-gray-900 dark:text-white">99</div>
      <div class="flex gap-2 mt-1">
        <span class="text-xs font-medium text-red-600 dark:text-red-400">{houseReps} R</span>
        <span class="text-xs font-medium text-blue-600 dark:text-blue-400">{houseDems} D</span>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">Ohio Senate</div>
      <div class="text-2xl font-bold text-gray-900 dark:text-white">33</div>
      <div class="flex gap-2 mt-1">
        <span class="text-xs font-medium text-red-600 dark:text-red-400">{senateReps} R</span>
        <span class="text-xs font-medium text-blue-600 dark:text-blue-400">{senateDems} D</span>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">US Senators</div>
      <div class="text-2xl font-bold text-gray-900 dark:text-white">2</div>
      <div class="flex gap-2 mt-1">
        <span class="text-xs font-medium text-red-600 dark:text-red-400">2 R</span>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">Total Officials</div>
      <div class="text-2xl font-bold text-gray-900 dark:text-white">{politiciansData.legislators.length}</div>
      <div class="text-xs text-gray-400 dark:text-gray-500 mt-1">State + Federal</div>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
      <div>
        <label for="q" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Search</label>
        <input type="text" id="q" name="q"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="Name or district..." />
      </div>
      
      <div>
        <label for="chamber" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Chamber</label>
        <select id="chamber" name="chamber"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
          <option value="">All Chambers</option>
          <option value="House">Ohio House</option>
          <option value="Senate">Ohio Senate</option>
          <option value="US Senate">US Senate</option>
        </select>
      </div>
      
      <div>
        <label for="party" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Party</label>
        <select id="party" name="party"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
          <option value="">All Parties</option>
          <option value="R">Republican</option>
          <option value="D">Democrat</option>
        </select>
      </div>
      
      <div class="flex items-end">
        <button type="button" id="filter-btn" class="w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-primary-600 dark:hover:bg-primary-700">
          Filter
        </button>
      </div>
    </div>
    
    <div id="filter-info" class="hidden mt-3 flex items-center gap-2">
      <span class="text-sm text-gray-500 dark:text-gray-400">
        Showing <span id="showing-count">0</span> of {politiciansData.legislators.length}
      </span>
      <button type="button" id="clear-btn" class="text-sm text-red-600 hover:text-red-700 dark:text-red-400">Clear filters</button>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="mb-6 flex flex-wrap gap-3">
    <a href="https://www.legislature.ohio.gov/members/district-maps" target="_blank" rel="noopener noreferrer"
       class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
      </svg>
      Find My District
    </a>
  </div>

  <!-- Politicians Grid -->
  <div id="politicians-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    {allLegislators.map((leg) => {
      const chamberInfo = getChamberBadge(leg.chamber);
      return (
        <div class="politician-card bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-200 border-l-4"
             data-chamber={leg.chamber}
             data-party={leg.party}
             data-name={leg.name.toLowerCase()}
             data-district={leg.district || ''}
             class:list={[getPartyBorder(leg.party)]}>
          <!-- Header with party color -->
          <div class:list={["bg-gradient-to-r px-4 py-3", getPartyGradient(leg.party)]}>
            <div class="flex items-center gap-3">
              <div class:list={["w-12 h-12 rounded-full flex items-center justify-center text-lg font-bold", getPartyAvatar(leg.party)]}>
                {getInitials(leg.name)}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-white truncate text-sm">{leg.name}</h3>
                <div class="flex items-center gap-2 mt-0.5">
                  <span class:list={["text-xs px-1.5 py-0.5 rounded", chamberInfo.class]}>
                    {chamberInfo.icon} {chamberInfo.label}
                  </span>
                  {leg.district && (
                    <span class="text-xs text-white/80">District {leg.district}</span>
                  )}
                </div>
              </div>
            </div>
          </div>
          
          <!-- Content -->
          <div class="p-4">
            {leg.note && (
              <div class="mb-3 text-xs font-medium text-amber-600 dark:text-amber-400 flex items-center gap-1">
                <span>⭐</span> {leg.note}
              </div>
            )}
            
            <div class="space-y-2">
              {leg.phone && (
                <a href={`tel:${leg.phone}`} class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                  <span>{leg.phone}</span>
                </a>
              )}
              {leg.email && (
                <a href={`mailto:${leg.email}`} class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors truncate">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  <span class="truncate">{leg.email}</span>
                </a>
              )}
              {leg.website && (
                <a href={leg.website} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                  </svg>
                  <span>Official Website</span>
                </a>
              )}
            </div>
            
            <!-- Contact Button -->
            <div class="mt-4">
              <a href={`mailto:${leg.email || ''}?subject=Ohio%20Fraud%20Concern&body=Dear%20${encodeURIComponent(leg.name.split(' ')[0])}%2C%0A%0AI%20am%20writing%20to%20express%20concern%20about%20federal%20funding%20and%20potential%20fraud%20in%20Ohio.%0A%0AAs%20my%20representative%2C%20I%20urge%20you%20to%20investigate%20and%20ensure%20accountability%20for%20how%20federal%20funds%20are%20being%20used%20in%20our%20state.%0A%0AThank%20you%20for%20your%20attention%20to%20this%20matter.%0A%0ASincerely%2C%0A[Your%20Name]%0A[Your%20Address]`}
                 class:list={["w-full inline-flex items-center justify-center gap-2 px-3 py-2 text-white text-sm font-medium rounded-lg transition-colors", getPartyButton(leg.party)]}>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                Contact About Ohio Fraud
              </a>
            </div>
          </div>
        </div>
      );
    })}
  </div>
  
  <div id="no-results" class="hidden bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 text-center">
    <svg class="w-12 h-12 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    <p class="text-gray-500 dark:text-gray-400">No politicians found matching your filters.</p>
    <button type="button" id="clear-btn-empty" class="inline-block mt-4 text-primary-600 hover:text-primary-700 dark:text-primary-400">Clear filters</button>
  </div>

  <!-- Data Source -->
  <div class="mt-8 text-center text-sm text-gray-500 dark:text-gray-400">
    <p>
      Data sourced from <a href="https://www.legislature.ohio.gov" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">Ohio Legislature</a>.
      Last updated: {politiciansData.lastUpdated}
    </p>
  </div>
</DashboardLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('q');
    const chamberSelect = document.getElementById('chamber');
    const partySelect = document.getElementById('party');
    const filterBtn = document.getElementById('filter-btn');
    const clearBtn = document.getElementById('clear-btn');
    const clearBtnEmpty = document.getElementById('clear-btn-empty');
    const filterInfo = document.getElementById('filter-info');
    const showingCount = document.getElementById('showing-count');
    const noResults = document.getElementById('no-results');
    const grid = document.getElementById('politicians-grid');
    const cards = document.querySelectorAll('.politician-card');
    const totalCount = cards.length;

    function applyFilters() {
      const q = searchInput.value.toLowerCase().trim();
      const chamber = chamberSelect.value;
      const party = partySelect.value;
      
      let visibleCount = 0;
      
      cards.forEach(card => {
        const cardChamber = card.dataset.chamber;
        const cardParty = card.dataset.party;
        const cardName = card.dataset.name;
        const cardDistrict = card.dataset.district;
        
        let show = true;
        
        if (chamber && cardChamber !== chamber) show = false;
        if (party && cardParty !== party) show = false;
        if (q && !cardName.includes(q) && !cardDistrict.includes(q)) show = false;
        
        card.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });
      
      // Update UI
      const hasFilters = q || chamber || party;
      filterInfo.classList.toggle('hidden', !hasFilters);
      showingCount.textContent = visibleCount;
      
      noResults.classList.toggle('hidden', visibleCount > 0);
      grid.classList.toggle('hidden', visibleCount === 0);
    }
    
    function clearFilters() {
      searchInput.value = '';
      chamberSelect.value = '';
      partySelect.value = '';
      applyFilters();
    }
    
    // Event listeners
    filterBtn.addEventListener('click', applyFilters);
    clearBtn.addEventListener('click', clearFilters);
    clearBtnEmpty.addEventListener('click', clearFilters);
    
    // Also filter on Enter key in search
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') applyFilters();
    });
    
    // Filter on select change for better UX
    chamberSelect.addEventListener('change', applyFilters);
    partySelect.addEventListener('change', applyFilters);
  });
</script>
