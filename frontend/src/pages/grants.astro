---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout 
  title="Federal Grants & Awards in Ohio" 
  description="Search billions in federal grants awarded to Ohio organizations. Browse by agency, recipient, amount. Data from USAspending.gov updated regularly."
  keywords="federal grants Ohio, government grants Ohio, USAspending Ohio, grant recipients Ohio, HHS grants Ohio, DOE grants Ohio, federal funding database"
>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Grants & Awards</h1>
    <p class="text-gray-500 dark:text-gray-400">Browse federal and state funding to Ohio recipients</p>
  </div>

  <!-- Error banner (hidden) -->
  <div id="error-banner" class="hidden p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
    <span class="font-medium">Error:</span> <span id="error-message"></span>
  </div>

  <!-- Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 mb-6">
    <form id="filter-form" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 sm:gap-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <label for="q" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Search</label>
        <input type="text" id="q" name="q" 
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="Recipient name..." />
      </div>
      
      <div>
        <label for="source" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Data Source</label>
        <select id="source" name="source"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
          <option value="">All Sources</option>
          <option value="usaspending">🇺🇸 Federal (USAspending)</option>
          <option value="ohio_checkbook">🏛️ Ohio Checkbook</option>
          <option value="sba_ppp">💼 SBA PPP Loans</option>
        </select>
      </div>
      
      <div>
        <label for="agency_code" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Agency</label>
        <select id="agency_code" name="agency_code"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
          <option value="">All Agencies</option>
        </select>
      </div>
      
      <div>
        <label for="award_type" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Type</label>
        <select id="award_type" name="award_type"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
          <option value="">All Types</option>
          <option value="block_grant">Block Grant</option>
          <option value="formula_grant">Formula Grant</option>
          <option value="project_grant">Project Grant</option>
          <option value="cooperative_agreement">Cooperative Agreement</option>
          <option value="direct_payment">Direct Payment</option>
          <option value="direct_loan">Direct Loan</option>
          <option value="guaranteed_loan">Guaranteed Loan</option>
          <option value="contract">Contract</option>
        </select>
      </div>
      
      <div class="flex items-end sm:col-span-2 lg:col-span-1">
        <button type="submit" class="w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5">
          Apply Filters
        </button>
      </div>
    </form>
  </div>

  <!-- Results info -->
  <div class="flex justify-between items-center mb-4">
    <p id="results-info" class="text-sm text-gray-500 dark:text-gray-400">Loading...</p>
    <div class="flex items-center gap-2">
      <span class="text-sm text-gray-500 dark:text-gray-400">Sort:</span>
      <select id="sort-select" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
        <option value="amount-desc">Amount (High to Low)</option>
        <option value="amount-asc">Amount (Low to High)</option>
        <option value="date-desc">Date (Newest)</option>
        <option value="date-asc">Date (Oldest)</option>
      </select>
    </div>
  </div>

  <!-- Loading State -->
  <div id="loading-state" class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-8">
    <div class="flex items-center justify-center">
      <svg class="animate-spin h-8 w-8 text-primary-600" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <span class="ml-2 text-gray-500">Loading awards...</span>
    </div>
  </div>

  <!-- Awards Table -->
  <div id="awards-table" class="hidden bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700">
          <tr class="text-gray-600 dark:text-gray-300">
            <th class="px-4 py-3">Recipient</th>
            <th class="px-4 py-3 text-center">Source / Agency</th>
            <th class="px-4 py-3 text-center">Type</th>
            <th class="px-4 py-3">Description</th>
            <th class="px-4 py-3 text-right">Amount</th>
            <th class="px-4 py-3 text-right">Date</th>
          </tr>
        </thead>
        <tbody id="awards-body" class="divide-y divide-gray-200 dark:divide-gray-700">
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="hidden flex justify-center mt-6">
    <nav class="inline-flex rounded-md shadow-sm -space-x-px">
      <button id="prev-btn" class="px-4 py-2 text-sm font-medium rounded-l-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600">Previous</button>
      <span id="page-info" class="px-4 py-2 text-sm font-medium bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">Page 1</span>
      <button id="next-btn" class="px-4 py-2 text-sm font-medium rounded-r-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600">Next</button>
    </nav>
  </div>
</DashboardLayout>

<script is:inline>
  const apiBase = window.location.hostname === 'localhost' ? 'http://localhost:8000' : '';
  let currentPage = 1;
  let sortBy = 'amount';
  let sortOrder = 'desc';
  let agenciesLoaded = false;
  let pendingAgencyCode = '';
  
  // Helpers
  function formatCurrency(amount) {
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(amount);
  }
  
  function formatDate(dateStr) {
    if (!dateStr) return '—';
    return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }
  
  function getAwardTypeName(type) {
    const names = { block_grant: 'Block Grant', formula_grant: 'Formula Grant', project_grant: 'Project Grant', cooperative_agreement: 'Cooperative', direct_loan: 'Direct Loan', guaranteed_loan: 'Guaranteed Loan', direct_payment: 'Direct Payment', contract: 'Contract', loan: 'PPP Loan' };
    return names[type] || type;
  }
  
  function getSourceIcon(source) {
    return { usaspending: '🇺🇸', ohio_checkbook: '🏛️', sba_ppp: '💼' }[source] || '📄';
  }
  
  function getSourceClass(source) {
    return { usaspending: 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300', ohio_checkbook: 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-300', sba_ppp: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' }[source] || 'bg-gray-100 text-gray-800';
  }
  
  // Load agencies for dropdown
  async function loadAgencies() {
    try {
      const res = await fetch(`${apiBase}/api/stats/agencies`);
      const agencies = await res.json();
      const select = document.getElementById('agency_code');
      agencies.forEach(a => {
        const opt = document.createElement('option');
        opt.value = a.code;
        opt.textContent = `${a.code} - ${a.name}`;
        select.appendChild(opt);
      });
      agenciesLoaded = true;
      
      // If there was a pending agency code, set it now
      if (pendingAgencyCode) {
        select.value = pendingAgencyCode;
        pendingAgencyCode = '';
      }
    } catch (e) { console.error('Failed to load agencies', e); }
  }
  
  // Load awards
  async function loadAwards() {
    document.getElementById('loading-state').classList.remove('hidden');
    document.getElementById('awards-table').classList.add('hidden');
    
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q') || '';
    const source = params.get('source') || '';
    const agency_code = params.get('agency_code') || '';
    const award_type = params.get('award_type') || '';
    currentPage = parseInt(params.get('page') || '1');
    sortBy = params.get('sort_by') || 'amount';
    sortOrder = params.get('sort_order') || 'desc';
    
    // Set form values
    document.getElementById('q').value = q;
    document.getElementById('source').value = source;
    document.getElementById('award_type').value = award_type;
    document.getElementById('sort-select').value = `${sortBy}-${sortOrder}`;
    
    // Handle agency dropdown - may not be loaded yet
    if (agenciesLoaded) {
      document.getElementById('agency_code').value = agency_code;
    } else {
      pendingAgencyCode = agency_code;
    }
    
    try {
      const apiParams = new URLSearchParams();
      if (q) apiParams.set('q', q);
      if (source) apiParams.set('source', source);
      if (agency_code) apiParams.set('agency_code', agency_code);
      if (award_type) apiParams.set('award_type', award_type);
      apiParams.set('page', String(currentPage));
      apiParams.set('page_size', '25');
      apiParams.set('sort_by', sortBy);
      apiParams.set('sort_order', sortOrder);
      apiParams.set('skip_count', 'true');  // Skip expensive COUNT query for faster response
      apiParams.set('fast', 'true');  // Use fast mode - batch fetch recipients/agencies

      const res = await fetch(`${apiBase}/api/awards?${apiParams}`);
      if (!res.ok) throw new Error('Failed to load awards');
      const data = await res.json();
      
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('awards-table').classList.remove('hidden');
      
      // Update results info
      document.getElementById('results-info').textContent = data.items.length > 0 
        ? `Showing ${((currentPage - 1) * 25) + 1} - ${Math.min(currentPage * 25, data.total_count || data.items.length)} ${data.total_count ? `of ${data.total_count.toLocaleString()}` : ''}`
        : 'No results';
      
      // Render table
      const tbody = document.getElementById('awards-body');
      tbody.innerHTML = data.items.length > 0 ? data.items.map(award => `
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
          <td class="px-4 py-3">
            <div class="font-medium text-gray-900 dark:text-white truncate">${award.recipient_name}</div>
            ${award.recipient_city ? `<div class="text-xs text-gray-500 dark:text-gray-400">${award.recipient_city}</div>` : ''}
          </td>
          <td class="px-4 py-3 text-center">
            <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded ${getSourceClass(award.source)}">${getSourceIcon(award.source)}</span>
            ${award.agency_code ? `<div class="text-xs text-gray-500 dark:text-gray-400 mt-1">${award.agency_code}</div>` : ''}
          </td>
          <td class="px-4 py-3 text-center">
            <span class="chip chip-grant">${getAwardTypeName(award.award_type)}</span>
          </td>
          <td class="px-4 py-3">
            <div class="text-gray-600 dark:text-gray-300 truncate max-w-xs">${(award.description || '—').substring(0, 50)}${award.description?.length > 50 ? '...' : ''}</div>
          </td>
          <td class="px-4 py-3 text-right font-semibold text-green-600 dark:text-green-400 whitespace-nowrap">${formatCurrency(award.amount)}</td>
          <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400 whitespace-nowrap">${formatDate(award.award_date)}</td>
        </tr>
      `).join('') : '<tr><td colspan="6" class="text-center py-8 text-gray-500 dark:text-gray-400">No awards found</td></tr>';
      
      // Pagination
      const pagination = document.getElementById('pagination');
      if (data.has_next || data.has_prev) {
        pagination.classList.remove('hidden');
        document.getElementById('page-info').textContent = `Page ${currentPage}`;
        document.getElementById('prev-btn').disabled = !data.has_prev;
        document.getElementById('next-btn').disabled = !data.has_next;
        document.getElementById('prev-btn').classList.toggle('opacity-50', !data.has_prev);
        document.getElementById('next-btn').classList.toggle('opacity-50', !data.has_next);
      } else {
        pagination.classList.add('hidden');
      }
    } catch (err) {
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-banner').classList.remove('hidden');
      document.getElementById('error-message').textContent = err.message || 'Unable to load awards';
    }
  }
  
  function navigate(newPage) {
    const params = new URLSearchParams(window.location.search);
    params.set('page', String(newPage));
    window.location.search = params.toString();
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    loadAgencies();
    loadAwards();
    
    document.getElementById('prev-btn').addEventListener('click', () => navigate(currentPage - 1));
    document.getElementById('next-btn').addEventListener('click', () => navigate(currentPage + 1));
    
    document.getElementById('sort-select').addEventListener('change', (e) => {
      const [sb, so] = e.target.value.split('-');
      const params = new URLSearchParams(window.location.search);
      params.set('sort_by', sb);
      params.set('sort_order', so);
      params.set('page', '1');
      window.location.search = params.toString();
    });
  });
</script>
