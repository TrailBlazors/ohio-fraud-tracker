---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getAwards, getAgencies, formatCurrency, formatDate, getAwardTypeName, getAwardTypeChipClass, getAwardTypeIcon, getAgencyChipClass } from '../lib/api';

// Get query params
const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') || '1');
const q = url.searchParams.get('q') || '';
const agency_code = url.searchParams.get('agency_code') || '';
const award_type = url.searchParams.get('award_type') || '';
const sort_by = url.searchParams.get('sort_by') || 'amount';
const sort_order = url.searchParams.get('sort_order') || 'desc';

let awards;
let agencies = [];
let error = null;

try {
  [awards, agencies] = await Promise.all([
    getAwards({ q, agency_code, award_type, page, page_size: 25, sort_by, sort_order }),
    getAgencies(),
  ]);
} catch (e) {
  error = 'Unable to load awards. Make sure the API is running.';
  awards = { items: [], total_count: 0, total_pages: 0, page: 1, has_next: false, has_prev: false };
}

// Build pagination URLs
const baseUrl = '/grants';
const buildUrl = (newPage: number) => {
  const params = new URLSearchParams();
  if (q) params.set('q', q);
  if (agency_code) params.set('agency_code', agency_code);
  if (award_type) params.set('award_type', award_type);
  params.set('sort_by', sort_by);
  params.set('sort_order', sort_order);
  params.set('page', String(newPage));
  return `${baseUrl}?${params.toString()}`;
};
---

<DashboardLayout title="Grants & Awards">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Grants & Awards</h1>
    <p class="text-gray-500 dark:text-gray-400">Browse all federal funding to Ohio recipients</p>
  </div>

  {error && (
    <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
      <span class="font-medium">Error:</span> {error}
    </div>
  )}

  <!-- Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 mb-6">
    <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <!-- Search -->
      <div>
        <label for="q" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Search</label>
        <input type="text" id="q" name="q" value={q} 
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="Recipient name, keyword..." />
      </div>
      
      <!-- Agency filter -->
      <div>
        <label for="agency_code" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Agency</label>
        <select id="agency_code" name="agency_code"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
          <option value="">All Agencies</option>
          {agencies.map((a) => (
            <option value={a.code} selected={agency_code === a.code}>{a.code} - {a.name}</option>
          ))}
        </select>
      </div>
      
      <!-- Type filter -->
      <div>
        <label for="award_type" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Type</label>
        <select id="award_type" name="award_type"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
          <option value="">All Types</option>
          <option value="block_grant" selected={award_type === 'block_grant'}>Block Grant</option>
          <option value="formula_grant" selected={award_type === 'formula_grant'}>Formula Grant</option>
          <option value="project_grant" selected={award_type === 'project_grant'}>Project Grant</option>
          <option value="cooperative_agreement" selected={award_type === 'cooperative_agreement'}>Cooperative Agreement</option>
          <option value="direct_loan" selected={award_type === 'direct_loan'}>Direct Loan</option>
          <option value="guaranteed_loan" selected={award_type === 'guaranteed_loan'}>Guaranteed Loan</option>
        </select>
      </div>
      
      <!-- Submit -->
      <div class="flex items-end">
        <button type="submit" class="w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-primary-600 dark:hover:bg-primary-700">
          Apply Filters
        </button>
      </div>
      
      <input type="hidden" name="sort_by" value={sort_by} />
      <input type="hidden" name="sort_order" value={sort_order} />
    </form>
  </div>

  <!-- Results count -->
  <div class="flex justify-between items-center mb-4">
    <p class="text-sm text-gray-500 dark:text-gray-400">
      Showing {((page - 1) * 25) + 1} - {Math.min(page * 25, awards.total_count)} of {awards.total_count.toLocaleString()} results
    </p>
    <div class="flex items-center gap-2">
      <span class="text-sm text-gray-500 dark:text-gray-400">Sort by:</span>
      <select id="sort-select" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
        <option value="amount-desc" selected={sort_by === 'amount' && sort_order === 'desc'}>Amount (High to Low)</option>
        <option value="amount-asc" selected={sort_by === 'amount' && sort_order === 'asc'}>Amount (Low to High)</option>
        <option value="date-desc" selected={sort_by === 'date' && sort_order === 'desc'}>Date (Newest)</option>
        <option value="date-asc" selected={sort_by === 'date' && sort_order === 'asc'}>Date (Oldest)</option>
        <option value="recipient-asc" selected={sort_by === 'recipient' && sort_order === 'asc'}>Recipient (A-Z)</option>
      </select>
    </div>
  </div>

  <!-- Awards Table -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700">
          <tr class="text-gray-600 dark:text-gray-300">
            <th class="px-4 py-3 w-1/4">Recipient</th>
            <th class="px-4 py-3 w-20 text-center">Agency</th>
            <th class="px-4 py-3 w-36 text-center">Type</th>
            <th class="px-4 py-3 w-1/4">Description</th>
            <th class="px-4 py-3 w-28 text-right">Amount</th>
            <th class="px-4 py-3 w-28 text-right">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          {awards.items.map((award) => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900 dark:text-white truncate">{award.recipient_name}</div>
                {award.recipient_city && (
                  <div class="text-xs text-gray-500 dark:text-gray-400">{award.recipient_city}</div>
                )}
              </td>
              <td class="px-4 py-3 text-center">
                {award.agency_code ? (
                  <span class={`chip ${getAgencyChipClass(award.agency_code)}`}>
                    {award.agency_code}
                  </span>
                ) : (
                  <span class="text-gray-400">—</span>
                )}
              </td>
              <td class="px-4 py-3 text-center">
                <span class={`chip ${getAwardTypeChipClass(award.award_type)}`}>
                  <span class="chip-icon">{getAwardTypeIcon(award.award_type)}</span>
                  {getAwardTypeName(award.award_type)}
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="text-gray-600 dark:text-gray-300 truncate max-w-xs" title={award.description || ''}>
                  {award.description?.substring(0, 50) || '—'}{award.description && award.description.length > 50 ? '...' : ''}
                </div>
              </td>
              <td class="px-4 py-3 text-right font-semibold text-green-600 dark:text-green-400 whitespace-nowrap">
                {formatCurrency(award.amount)}
              </td>
              <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400 whitespace-nowrap">
                {formatDate(award.award_date)}
              </td>
            </tr>
          ))}
          {awards.items.length === 0 && (
            <tr>
              <td colspan="6" class="text-center py-8 text-gray-500 dark:text-gray-400">
                No awards found matching your criteria
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  {awards.total_pages > 1 && (
    <div class="flex justify-center mt-6">
      <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
        <a href={awards.has_prev ? buildUrl(page - 1) : '#'} 
          class={`relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-l-lg border ${awards.has_prev ? 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-gray-300 dark:border-gray-600' : 'bg-gray-100 dark:bg-gray-900 text-gray-400 cursor-not-allowed border-gray-200 dark:border-gray-700'}`}>
          Previous
        </a>
        
        <span class="relative inline-flex items-center px-4 py-2 text-sm font-medium bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">
          Page {page} of {awards.total_pages}
        </span>
        
        <a href={awards.has_next ? buildUrl(page + 1) : '#'}
          class={`relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-r-lg border ${awards.has_next ? 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-gray-300 dark:border-gray-600' : 'bg-gray-100 dark:bg-gray-900 text-gray-400 cursor-not-allowed border-gray-200 dark:border-gray-700'}`}>
          Next
        </a>
      </nav>
    </div>
  )}

  <script is:inline>
    // Sort select handler
    document.getElementById('sort-select')?.addEventListener('change', (e) => {
      const [sortBy, sortOrder] = e.target.value.split('-');
      const url = new URL(window.location);
      url.searchParams.set('sort_by', sortBy);
      url.searchParams.set('sort_order', sortOrder);
      url.searchParams.set('page', '1');
      window.location.href = url.toString();
    });
  </script>
</DashboardLayout>
