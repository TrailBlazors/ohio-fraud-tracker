---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout 
  title="Ohio Grant & Loan Recipients - Who Gets Federal Money" 
  description="Search organizations receiving federal funding in Ohio. Universities, hospitals, nonprofits, businesses - see who gets taxpayer money and how much."
  keywords="Ohio grant recipients, federal funding recipients Ohio, government contractors Ohio, nonprofit grants Ohio, university funding Ohio"
>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Recipients</h1>
    <p class="text-gray-500 dark:text-gray-400">Organizations and businesses receiving federal funding in Ohio</p>
  </div>

  <!-- Error banner (hidden) -->
  <div id="error-banner" class="hidden p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
    <span class="font-medium">Error:</span> <span id="error-message"></span>
  </div>

  <!-- Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 mb-6">
    <form id="filter-form" class="grid grid-cols-1 sm:grid-cols-4 gap-3 sm:gap-4">
      <div class="sm:col-span-2">
        <label for="q" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Search</label>
        <input type="text" id="q" name="q"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="Organization name..." />
      </div>
      <div>
        <label for="city" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">City</label>
        <input type="text" id="city" name="city"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="e.g., Columbus..." />
      </div>
      <div class="flex items-end">
        <button type="submit" class="w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 transition-all duration-200 hover:scale-[1.02]">
          <span class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            Search
          </span>
        </button>
      </div>
    </form>
  </div>

  <!-- Results info -->
  <div class="flex justify-between items-center mb-4">
    <p id="results-info" class="text-sm text-gray-500 dark:text-gray-400">Loading...</p>
    <div class="flex items-center gap-2 text-xs text-gray-400">
      <span class="flex items-center gap-1">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span> Live Data
      </span>
    </div>
  </div>

  <!-- Loading State -->
  <div id="loading-state" class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <div class="animate-pulse">
      <div class="h-12 bg-gray-100 dark:bg-gray-700"></div>
      {[1,2,3,4,5,6,7,8].map(() => (
        <div class="border-t border-gray-200 dark:border-gray-700 p-4 flex gap-4">
          <div class="h-4 w-1/3 bg-gray-200 dark:bg-gray-600 rounded"></div>
          <div class="h-4 w-1/6 bg-gray-200 dark:bg-gray-600 rounded"></div>
          <div class="h-4 w-1/6 bg-gray-200 dark:bg-gray-600 rounded"></div>
          <div class="h-4 w-1/6 bg-gray-200 dark:bg-gray-600 rounded"></div>
          <div class="h-4 w-1/6 bg-gray-200 dark:bg-gray-600 rounded"></div>
        </div>
      ))}
    </div>
  </div>

  <!-- Data Table -->
  <div id="table-container" class="hidden bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700 sticky top-0">
          <tr class="text-gray-600 dark:text-gray-300">
            <th class="px-4 py-3 cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors group" data-sort="name">
              <span class="flex items-center gap-1">
                Recipient
                <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"></path>
                </svg>
              </span>
            </th>
            <th class="px-4 py-3 cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors group" data-sort="city">
              <span class="flex items-center gap-1">
                Location
                <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"></path>
                </svg>
              </span>
            </th>
            <th class="px-4 py-3 text-right cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors group" data-sort="total_amount">
              <span class="flex items-center justify-end gap-1">
                Total Funding
                <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"></path>
                </svg>
              </span>
            </th>
            <th class="px-4 py-3 text-center">Awards</th>
            <th class="px-4 py-3 text-center">Type</th>
            <th class="px-4 py-3 text-center">Status</th>
            <th class="px-4 py-3 text-center">Action</th>
          </tr>
        </thead>
        <tbody id="recipients-tbody" class="divide-y divide-gray-200 dark:divide-gray-700">
        </tbody>
      </table>
    </div>
  </div>

  <!-- Empty State -->
  <div id="empty-state" class="hidden bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 text-center">
    <svg class="w-16 h-16 mx-auto text-gray-300 dark:text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
    </svg>
    <p class="text-gray-500 dark:text-gray-400 text-lg">No recipients found</p>
    <p class="text-gray-400 dark:text-gray-500 text-sm mt-1">Try adjusting your search criteria</p>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="hidden flex flex-col sm:flex-row justify-between items-center mt-6 gap-4">
    <p id="showing-info" class="text-sm text-gray-500 dark:text-gray-400"></p>
    <nav class="inline-flex rounded-md shadow-sm -space-x-px">
      <button id="prev-btn" class="px-4 py-2 text-sm font-medium rounded-l-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Previous
        </span>
      </button>
      <span id="page-info" class="px-4 py-2 text-sm font-medium bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">Page 1</span>
      <button id="next-btn" class="px-4 py-2 text-sm font-medium rounded-r-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        <span class="flex items-center gap-1">
          Next
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </span>
      </button>
    </nav>
  </div>

  <style>
    /* Funding amount color scale */
    .funding-tier-5 { @apply text-emerald-600 dark:text-emerald-400 font-bold; }
    .funding-tier-4 { @apply text-green-600 dark:text-green-400 font-semibold; }
    .funding-tier-3 { @apply text-lime-600 dark:text-lime-400 font-medium; }
    .funding-tier-2 { @apply text-gray-700 dark:text-gray-300; }
    .funding-tier-1 { @apply text-gray-500 dark:text-gray-400; }
    
    /* Animated gradient for mega recipients */
    .mega-recipient {
      background: linear-gradient(90deg, 
        rgba(16, 185, 129, 0.1) 0%, 
        rgba(59, 130, 246, 0.1) 50%, 
        rgba(16, 185, 129, 0.1) 100%);
      background-size: 200% 100%;
      animation: shimmer 3s ease-in-out infinite;
    }
    
    @keyframes shimmer {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    
    /* Row hover effect */
    tbody tr {
      transition: all 0.15s ease;
    }
    
    tbody tr:hover {
      transform: scale(1.005);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    
    /* Status chip animations */
    .status-chip {
      transition: all 0.2s ease;
    }
    
    .status-chip:hover {
      transform: scale(1.05);
    }
    
    /* Type badge pulse for nonprofits */
    .type-nonprofit {
      animation: pulse-subtle 2s ease-in-out infinite;
    }
    
    @keyframes pulse-subtle {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.8; }
    }
  </style>

</DashboardLayout>

<script is:inline>
  const apiBase = window.location.hostname === 'localhost' ? 'http://localhost:8000' : '';
  let currentPage = 1;
  let pageSize = 25;
  let totalCount = 0;
  
  function formatCurrency(amount) {
    if (amount >= 1e9) return `$${(amount / 1e9).toFixed(2)}B`;
    if (amount >= 1e6) return `$${(amount / 1e6).toFixed(1)}M`;
    if (amount >= 1e3) return `$${(amount / 1e3).toFixed(0)}K`;
    return `$${amount.toLocaleString()}`;
  }
  
  function getFundingTier(amount) {
    if (amount >= 1e9) return 5;      // Billions
    if (amount >= 100e6) return 4;    // 100M+
    if (amount >= 10e6) return 3;     // 10M+
    if (amount >= 1e6) return 2;      // 1M+
    return 1;                          // Less than 1M
  }
  
  function getTypeChip(recipient) {
    // Determine type based on name patterns or flags
    const name = (recipient.name || '').toLowerCase();
    
    if (recipient.is_nonprofit || name.includes('university') || name.includes('college') || 
        name.includes('hospital') || name.includes('foundation') || name.includes('church')) {
      return `<span class="type-nonprofit inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200">
        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"></path>
        </svg>
        Nonprofit
      </span>`;
    }
    
    if (name.includes('llc') || name.includes('inc') || name.includes('corp') || name.includes('co.')) {
      return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 01-1 1h-2a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd"></path>
        </svg>
        Business
      </span>`;
    }
    
    if (name.includes('city of') || name.includes('county') || name.includes('state of') || name.includes('department')) {
      return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200">
        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"></path>
        </svg>
        Government
      </span>`;
    }
    
    return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300">
      Other
    </span>`;
  }
  
  function getStatusChip(status) {
    const configs = {
      active: {
        bg: 'bg-green-100 dark:bg-green-900/50',
        text: 'text-green-700 dark:text-green-300',
        icon: `<span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>`,
        label: 'Active'
      },
      inactive: {
        bg: 'bg-red-100 dark:bg-red-900/50',
        text: 'text-red-700 dark:text-red-300',
        icon: `<span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>`,
        label: 'Inactive'
      },
      dissolved: {
        bg: 'bg-red-100 dark:bg-red-900/50',
        text: 'text-red-700 dark:text-red-300',
        icon: `<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>`,
        label: 'Dissolved'
      },
      unknown: {
        bg: 'bg-gray-100 dark:bg-gray-700',
        text: 'text-gray-600 dark:text-gray-400',
        icon: `<span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>`,
        label: 'Unknown'
      }
    };
    
    const config = configs[status] || configs.unknown;
    return `<span class="status-chip inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-medium ${config.bg} ${config.text}">
      ${config.icon}
      ${config.label}
    </span>`;
  }
  
  function renderRow(r) {
    const recipientId = r.id || r.recipient_id;
    if (!recipientId) return '';
    
    const tier = getFundingTier(r.total_amount || 0);
    const isMega = tier >= 4;
    
    return `
      <tr class="${isMega ? 'mega-recipient' : ''} hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer transition-all" 
          onclick="window.location.href='/recipients/view?id=${recipientId}'">
        <td class="px-4 py-3">
          <div class="flex items-center gap-2">
            ${isMega ? `<span class="text-amber-500" title="Major Recipient">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
            </span>` : ''}
            <div>
              <p class="font-medium text-gray-900 dark:text-white truncate max-w-xs" title="${r.name}">${r.name}</p>
              ${r.ein ? `<p class="text-xs text-gray-400">EIN: ${r.ein}</p>` : ''}
            </div>
          </div>
        </td>
        <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
          <span class="flex items-center gap-1">
            <svg class="w-3 h-3 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
            </svg>
            ${r.city || 'Ohio'}${r.state ? `, ${r.state}` : ''}
          </span>
        </td>
        <td class="px-4 py-3 text-right">
          <span class="funding-tier-${tier} whitespace-nowrap">${formatCurrency(r.total_amount || 0)}</span>
        </td>
        <td class="px-4 py-3 text-center">
          <span class="inline-flex items-center justify-center min-w-[2rem] px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
            ${(r.total_awards || 0).toLocaleString()}
          </span>
        </td>
        <td class="px-4 py-3 text-center">
          ${getTypeChip(r)}
        </td>
        <td class="px-4 py-3 text-center">
          ${getStatusChip(r.business_status || 'unknown')}
        </td>
        <td class="px-4 py-3 text-center">
          <a href="/recipients/view?id=${recipientId}" 
             class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/30 rounded-lg hover:bg-primary-100 dark:hover:bg-primary-900/50 transition-all hover:scale-105"
             onclick="event.stopPropagation()">
            View
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </td>
      </tr>
    `;
  }
  
  async function loadRecipients() {
    document.getElementById('loading-state').classList.remove('hidden');
    document.getElementById('table-container').classList.add('hidden');
    document.getElementById('empty-state').classList.add('hidden');
    document.getElementById('pagination').classList.add('hidden');
    
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q') || '';
    const city = params.get('city') || '';
    currentPage = parseInt(params.get('page') || '1');
    
    document.getElementById('q').value = q;
    document.getElementById('city').value = city;
    
    try {
      const apiParams = new URLSearchParams();
      if (q) apiParams.set('q', q);
      if (city) apiParams.set('city', city);
      apiParams.set('page', String(currentPage));
      apiParams.set('page_size', String(pageSize));
      
      const res = await fetch(`${apiBase}/api/recipients?${apiParams}`);
      if (!res.ok) throw new Error('Failed to load recipients');
      const data = await res.json();
      
      document.getElementById('loading-state').classList.add('hidden');
      
      if (!data.items || data.items.length === 0) {
        document.getElementById('empty-state').classList.remove('hidden');
        document.getElementById('results-info').textContent = 'No recipients found';
        return;
      }
      
      totalCount = data.total_count || data.items.length;
      document.getElementById('results-info').textContent = `${totalCount.toLocaleString()} recipients found`;
      
      const tbody = document.getElementById('recipients-tbody');
      tbody.innerHTML = data.items.map(renderRow).join('');
      
      document.getElementById('table-container').classList.remove('hidden');
      
      // Pagination
      const totalPages = Math.ceil(totalCount / pageSize);
      const start = (currentPage - 1) * pageSize + 1;
      const end = Math.min(currentPage * pageSize, totalCount);
      
      document.getElementById('showing-info').textContent = `Showing ${start.toLocaleString()}-${end.toLocaleString()} of ${totalCount.toLocaleString()}`;
      document.getElementById('page-info').textContent = `Page ${currentPage} of ${totalPages.toLocaleString()}`;
      
      document.getElementById('prev-btn').disabled = !data.has_prev;
      document.getElementById('next-btn').disabled = !data.has_next;
      
      document.getElementById('pagination').classList.remove('hidden');
      
    } catch (err) {
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-banner').classList.remove('hidden');
      document.getElementById('error-message').textContent = err.message;
    }
  }
  
  function navigate(newPage) {
    const params = new URLSearchParams(window.location.search);
    params.set('page', String(newPage));
    window.location.search = params.toString();
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    loadRecipients();
    
    document.getElementById('prev-btn').addEventListener('click', () => navigate(currentPage - 1));
    document.getElementById('next-btn').addEventListener('click', () => navigate(currentPage + 1));
    
    document.getElementById('filter-form').addEventListener('submit', (e) => {
      e.preventDefault();
      const q = document.getElementById('q').value;
      const city = document.getElementById('city').value;
      const params = new URLSearchParams();
      if (q) params.set('q', q);
      if (city) params.set('city', city);
      params.set('page', '1');
      window.location.search = params.toString();
    });
  });
</script>
</DashboardLayout>
