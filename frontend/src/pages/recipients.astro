---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getRecipients, formatCurrency, formatNumber, getStatusChipClass, getStatusIcon } from '../lib/api';

const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') || '1');
const q = url.searchParams.get('q') || '';
const city = url.searchParams.get('city') || '';
const sort_by = url.searchParams.get('sort_by') || 'total_amount';
const sort_order = url.searchParams.get('sort_order') || 'desc';

let recipients;
let error = null;

try {
  recipients = await getRecipients({ q, city, page, page_size: 25, sort_by, sort_order });
} catch (e) {
  error = 'Unable to load recipients. Make sure the API is running.';
  recipients = { items: [], total_count: 0, total_pages: 0, page: 1, has_next: false, has_prev: false };
}

const baseUrl = '/recipients';
const buildUrl = (newPage: number) => {
  const params = new URLSearchParams();
  if (q) params.set('q', q);
  if (city) params.set('city', city);
  params.set('sort_by', sort_by);
  params.set('sort_order', sort_order);
  params.set('page', String(newPage));
  return `${baseUrl}?${params.toString()}`;
};
---

<DashboardLayout title="Recipients">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Recipients</h1>
    <p class="text-gray-500 dark:text-gray-400">Organizations and businesses receiving federal funding in Ohio</p>
  </div>

  {error && (
    <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
      <span class="font-medium">Error:</span> {error}
    </div>
  )}

  <!-- Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 mb-6">
    <form method="get" class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label for="q" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Search</label>
        <input type="text" id="q" name="q" value={q}
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="Organization name..." />
      </div>
      
      <div>
        <label for="city" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">City</label>
        <input type="text" id="city" name="city" value={city}
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="e.g., Columbus, Cleveland..." />
      </div>
      
      <div class="flex items-end">
        <button type="submit" class="w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-primary-600 dark:hover:bg-primary-700">
          Search
        </button>
      </div>
      
      <input type="hidden" name="sort_by" value={sort_by} />
      <input type="hidden" name="sort_order" value={sort_order} />
    </form>
  </div>

  <!-- Results -->
  <div class="flex justify-between items-center mb-4">
    <p class="text-sm text-gray-500 dark:text-gray-400">
      {recipients.total_count.toLocaleString()} recipients found
    </p>
  </div>

  <!-- Recipients Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
    {recipients.items.map((recipient) => (
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-5 hover:shadow-lg transition-shadow">
        <div class="flex justify-between items-start mb-3">
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white truncate" title={recipient.name}>
              {recipient.name}
            </h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">
              {recipient.city || 'Ohio'}, {recipient.state}
            </p>
          </div>
          <span class={`chip ${getStatusChipClass(recipient.business_status)}`}>
            <span>{getStatusIcon(recipient.business_status)}</span>
            {recipient.business_status}
          </span>
        </div>
        
        <div class="grid grid-cols-2 gap-4 mt-4">
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">Total Funding</p>
            <p class="text-lg font-bold text-green-600 dark:text-green-400">${formatNumber(recipient.total_amount)}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">Awards</p>
            <p class="text-lg font-bold text-gray-900 dark:text-white">{recipient.total_awards}</p>
          </div>
        </div>
        
        <a href={`/recipients/${recipient.id}`} class="mt-4 inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400">
          View Details
          <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
    ))}
  </div>

  {recipients.items.length === 0 && (
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 text-center">
      <p class="text-gray-500 dark:text-gray-400">No recipients found matching your criteria</p>
    </div>
  )}

  <!-- Pagination -->
  {recipients.total_pages > 1 && (
    <div class="flex justify-center mt-6">
      <nav class="inline-flex rounded-md shadow-sm -space-x-px">
        <a href={recipients.has_prev ? buildUrl(page - 1) : '#'}
          class={`relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-l-lg border ${recipients.has_prev ? 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-gray-300 dark:border-gray-600' : 'bg-gray-100 dark:bg-gray-900 text-gray-400 cursor-not-allowed border-gray-200 dark:border-gray-700'}`}>
          Previous
        </a>
        <span class="relative inline-flex items-center px-4 py-2 text-sm font-medium bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">
          Page {page} of {recipients.total_pages}
        </span>
        <a href={recipients.has_next ? buildUrl(page + 1) : '#'}
          class={`relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-r-lg border ${recipients.has_next ? 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-gray-300 dark:border-gray-600' : 'bg-gray-100 dark:bg-gray-900 text-gray-400 cursor-not-allowed border-gray-200 dark:border-gray-700'}`}>
          Next
        </a>
      </nav>
    </div>
  )}
</DashboardLayout>
