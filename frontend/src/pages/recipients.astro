---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout 
  title="Ohio Grant & Loan Recipients - Who Gets Federal Money" 
  description="Search organizations receiving federal funding in Ohio. Universities, hospitals, nonprofits, businesses - see who gets taxpayer money and how much."
  keywords="Ohio grant recipients, federal funding recipients Ohio, government contractors Ohio, nonprofit grants Ohio, university funding Ohio"
>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Recipients</h1>
    <p class="text-gray-500 dark:text-gray-400">Organizations and businesses receiving federal funding in Ohio</p>
  </div>

  <!-- Error banner (hidden) -->
  <div id="error-banner" class="hidden p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
    <span class="font-medium">Error:</span> <span id="error-message"></span>
  </div>

  <!-- Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 mb-6">
    <form id="filter-form" class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
      <div>
        <label for="q" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Search</label>
        <input type="text" id="q" name="q"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="Organization name..." />
      </div>
      <div>
        <label for="city" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">City</label>
        <input type="text" id="city" name="city"
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="e.g., Columbus, Cleveland..." />
      </div>
      <div class="flex items-end">
        <button type="submit" class="w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5">
          Search
        </button>
      </div>
    </form>
  </div>

  <!-- Results info -->
  <p id="results-info" class="text-sm text-gray-500 dark:text-gray-400 mb-4">Loading...</p>

  <!-- Loading State -->
  <div id="loading-state" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
    {[1,2,3,4,5,6].map(() => (
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-5 animate-pulse">
        <div class="h-6 w-48 bg-gray-200 dark:bg-gray-700 rounded mb-2"></div>
        <div class="h-4 w-32 bg-gray-200 dark:bg-gray-700 rounded"></div>
      </div>
    ))}
  </div>

  <!-- Recipients Grid -->
  <div id="recipients-grid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6"></div>

  <!-- Empty State -->
  <div id="empty-state" class="hidden bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 text-center">
    <p class="text-gray-500 dark:text-gray-400">No recipients found matching your criteria</p>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="hidden flex justify-center mt-6">
    <nav class="inline-flex rounded-md shadow-sm -space-x-px">
      <button id="prev-btn" class="px-4 py-2 text-sm font-medium rounded-l-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600">Previous</button>
      <span id="page-info" class="px-4 py-2 text-sm font-medium bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">Page 1</span>
      <button id="next-btn" class="px-4 py-2 text-sm font-medium rounded-r-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600">Next</button>
    </nav>
  </div>
</DashboardLayout>

<script is:inline>
  const apiBase = window.location.hostname === 'localhost' ? 'http://localhost:8000' : '';
  let currentPage = 1;
  
  function getStatusChipClass(status) {
    const classes = {
      active: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300',
      inactive: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300',
      dissolved: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300',
      unknown: 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
    };
    return classes[status] || classes.unknown;
  }
  
  function getStatusIcon(status) {
    const icons = { active: '✓', inactive: '✗', dissolved: '✗', unknown: '?' };
    return icons[status] || '?';
  }
  
  async function loadRecipients() {
    document.getElementById('loading-state').classList.remove('hidden');
    document.getElementById('recipients-grid').classList.add('hidden');
    document.getElementById('empty-state').classList.add('hidden');
    
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q') || '';
    const city = params.get('city') || '';
    currentPage = parseInt(params.get('page') || '1');
    
    document.getElementById('q').value = q;
    document.getElementById('city').value = city;
    
    try {
      const apiParams = new URLSearchParams();
      if (q) apiParams.set('q', q);
      if (city) apiParams.set('city', city);
      apiParams.set('page', String(currentPage));
      apiParams.set('page_size', '24');
      apiParams.set('fast', 'true');
      
      const res = await fetch(`${apiBase}/api/recipients?${apiParams}`);
      if (!res.ok) throw new Error('Failed to load recipients');
      const data = await res.json();
      
      document.getElementById('loading-state').classList.add('hidden');
      
      if (!data.items || data.items.length === 0) {
        document.getElementById('empty-state').classList.remove('hidden');
        document.getElementById('results-info').textContent = 'No recipients found';
        return;
      }
      
      document.getElementById('results-info').textContent = `${data.total_count?.toLocaleString() || data.items.length} recipients found`;
      
      const grid = document.getElementById('recipients-grid');
      grid.classList.remove('hidden');
      grid.innerHTML = data.items.map(r => `
        <a href="/recipients/${r.id}" class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-5 hover:shadow-lg transition-shadow block">
          <div class="flex justify-between items-start mb-3">
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white truncate" title="${r.name}">${r.name}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">${r.city || 'Ohio'}, ${r.state || 'OH'}</p>
            </div>
            ${r.business_status && r.business_status !== 'unknown' ? `
              <span class="chip ${getStatusChipClass(r.business_status)}">
                <span>${getStatusIcon(r.business_status)}</span> ${r.business_status}
              </span>
            ` : ''}
          </div>
          <div class="mt-4 text-sm text-primary-600 dark:text-primary-400 flex items-center">
            View Details
            <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </div>
        </a>
      `).join('');
      
      const pagination = document.getElementById('pagination');
      if (data.has_next || data.has_prev) {
        pagination.classList.remove('hidden');
        document.getElementById('page-info').textContent = `Page ${currentPage}`;
        document.getElementById('prev-btn').disabled = !data.has_prev;
        document.getElementById('next-btn').disabled = !data.has_next;
        document.getElementById('prev-btn').classList.toggle('opacity-50', !data.has_prev);
        document.getElementById('next-btn').classList.toggle('opacity-50', !data.has_next);
      } else {
        pagination.classList.add('hidden');
      }
    } catch (err) {
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-banner').classList.remove('hidden');
      document.getElementById('error-message').textContent = err.message;
    }
  }
  
  function navigate(newPage) {
    const params = new URLSearchParams(window.location.search);
    params.set('page', String(newPage));
    window.location.search = params.toString();
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    loadRecipients();
    document.getElementById('prev-btn').addEventListener('click', () => navigate(currentPage - 1));
    document.getElementById('next-btn').addEventListener('click', () => navigate(currentPage + 1));
  });
</script>
