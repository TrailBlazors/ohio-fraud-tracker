---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getRecipient, getRecipientAwards, formatCurrency, formatDate, getAwardTypeName, getAwardTypeBadgeClass, formatNumber } from '../../lib/api';

const { id } = Astro.params;

let recipient = null;
let awards = null;
let error = null;

try {
  [recipient, awards] = await Promise.all([
    getRecipient(Number(id)),
    getRecipientAwards(Number(id), { page_size: 50 }),
  ]);
} catch (e) {
  error = `Unable to load recipient. ${e.message || 'Make sure the API is running.'}`;
}
---

<DashboardLayout title={recipient?.name || 'Recipient Details'}>
  {error && (
    <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
      <span class="font-medium">Error:</span> {error}
    </div>
  )}

  {recipient && (
    <>
      <!-- Header -->
      <div class="mb-6">
        <a href="/recipients" class="text-sm text-primary-600 hover:text-primary-700 dark:text-primary-400 mb-2 inline-flex items-center">
          <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"></path>
          </svg>
          Back to Recipients
        </a>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mt-2">{recipient.name}</h1>
        <p class="text-gray-500 dark:text-gray-400">
          {recipient.city ? `${recipient.city}, ` : ''}{recipient.state}
          {recipient.zip_code && ` ${recipient.zip_code}`}
        </p>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
          <p class="text-sm text-gray-500 dark:text-gray-400 uppercase font-medium">Total Funding</p>
          <p class="text-3xl font-bold text-green-600 dark:text-green-400 mt-2">
            ${formatNumber(recipient.total_amount)}
          </p>
        </div>
        
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
          <p class="text-sm text-gray-500 dark:text-gray-400 uppercase font-medium">Total Awards</p>
          <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2">
            {recipient.total_awards}
          </p>
        </div>
        
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
          <p class="text-sm text-gray-500 dark:text-gray-400 uppercase font-medium">Business Status</p>
          <p class="mt-2">
            <span class={`badge text-lg px-3 py-1 ${recipient.business_status === 'active' ? 'badge-success' : recipient.business_status === 'unknown' ? 'badge-warning' : 'badge-danger'}`}>
              {recipient.business_status}
            </span>
          </p>
        </div>
      </div>

      <!-- Awards Table -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md">
        <div class="p-6 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Awards History</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700">
              <tr class="text-gray-600 dark:text-gray-300">
                <th class="px-4 py-3">Agency</th>
                <th class="px-4 py-3">Type</th>
                <th class="px-4 py-3">Description</th>
                <th class="px-4 py-3 text-right">Amount</th>
                <th class="px-4 py-3 text-right">Date</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              {awards?.items.map((award) => (
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                  <td class="px-4 py-3">
                    <span class="font-medium text-gray-900 dark:text-white">{award.agency_code || '—'}</span>
                  </td>
                  <td class="px-4 py-3">
                    <span class={`badge ${getAwardTypeBadgeClass(award.award_type)}`}>
                      {getAwardTypeName(award.award_type)}
                    </span>
                  </td>
                  <td class="px-4 py-3 max-w-md">
                    <p class="text-gray-600 dark:text-gray-300 truncate" title={award.description || ''}>
                      {award.description?.substring(0, 80) || 'No description'}{award.description && award.description.length > 80 ? '...' : ''}
                    </p>
                  </td>
                  <td class="px-4 py-3 text-right font-semibold text-green-600 dark:text-green-400 whitespace-nowrap">
                    {formatCurrency(award.amount)}
                  </td>
                  <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400 whitespace-nowrap">
                    {formatDate(award.award_date)}
                  </td>
                </tr>
              ))}
              {(!awards || awards.items.length === 0) && (
                <tr>
                  <td colspan="5" class="text-center py-8 text-gray-500 dark:text-gray-400">
                    No awards found for this recipient
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
        {awards && awards.total_count > 50 && (
          <div class="p-4 border-t border-gray-200 dark:border-gray-700 text-center">
            <p class="text-sm text-gray-500 dark:text-gray-400">
              Showing 50 of {awards.total_count} awards
            </p>
          </div>
        )}
      </div>
    </>
  )}

  {!recipient && !error && (
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 text-center">
      <p class="text-gray-500 dark:text-gray-400">Recipient not found</p>
      <a href="/recipients" class="mt-4 inline-block text-primary-600 hover:text-primary-700 dark:text-primary-400">
        ← Back to Recipients
      </a>
    </div>
  )}
</DashboardLayout>
