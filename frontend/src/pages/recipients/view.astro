---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Recipient Details">
  <div id="recipient-content">
    <!-- Loading state -->
    <div id="loading-state" class="animate-pulse">
      <div class="mb-6">
        <div class="h-4 w-24 bg-gray-200 dark:bg-gray-700 rounded mb-2"></div>
        <div class="h-8 w-64 bg-gray-200 dark:bg-gray-700 rounded mb-2"></div>
        <div class="h-4 w-48 bg-gray-200 dark:bg-gray-700 rounded"></div>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        {[1, 2, 3].map(() => (
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
            <div class="h-4 w-24 bg-gray-200 dark:bg-gray-700 rounded mb-2"></div>
            <div class="h-8 w-32 bg-gray-200 dark:bg-gray-700 rounded"></div>
          </div>
        ))}
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
        <div class="h-6 w-32 bg-gray-200 dark:bg-gray-700 rounded mb-4"></div>
        <div class="space-y-3">
          {[1, 2, 3, 4, 5].map(() => (
            <div class="h-12 bg-gray-200 dark:bg-gray-700 rounded"></div>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Error state (hidden by default) -->
    <div id="error-state" class="hidden">
      <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
        <span class="font-medium">Error:</span> <span id="error-message">Unable to load recipient.</span>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 text-center">
        <p class="text-gray-500 dark:text-gray-400">Recipient not found</p>
        <a href="/recipients" class="mt-4 inline-block text-primary-600 hover:text-primary-700 dark:text-primary-400">
          ← Back to Recipients
        </a>
      </div>
    </div>
    
    <!-- Content (hidden by default, populated by JS) -->
    <div id="recipient-data" class="hidden"></div>
  </div>

  <script is:inline>
    // API base URL - use localhost for dev, production API otherwise
    const apiBase = window.location.hostname === 'localhost' ? 'http://localhost:8000' : '';
    
    // Get recipient ID from query params
    const urlParams = new URLSearchParams(window.location.search);
    const recipientId = urlParams.get('id');
    
    if (!recipientId) {
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-state').classList.remove('hidden');
      document.getElementById('error-message').textContent = 'No recipient ID provided';
    }
    
    // Format helpers
    function formatCurrency(amount) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(amount);
    }
    
    function formatNumber(num) {
      if (num >= 1000000000) return `${(num / 1000000000).toFixed(1)}B`;
      if (num >= 1000000) return `${(num / 1000000).toFixed(1)}M`;
      if (num >= 1000) return `${(num / 1000).toFixed(1)}K`;
      return num.toLocaleString();
    }
    
    function formatDate(dateStr) {
      if (!dateStr) return '—';
      return new Date(dateStr).toLocaleDateString('en-US', {
        year: 'numeric', month: 'short', day: 'numeric'
      });
    }
    
    function getAwardTypeName(type) {
      const names = {
        block_grant: 'Block Grant', formula_grant: 'Formula Grant', project_grant: 'Project Grant',
        cooperative_agreement: 'Cooperative', direct_loan: 'Direct Loan', guaranteed_loan: 'Guaranteed Loan',
        direct_payment: 'Direct Payment', insurance: 'Insurance', contract: 'Contract', loan: 'PPP Loan', other: 'Other'
      };
      return names[type] || type;
    }
    
    function getBadgeClass(type) {
      if (type.includes('grant')) return 'badge-success';
      if (type.includes('loan')) return 'badge-info';
      if (type.includes('contract')) return 'badge-warning';
      return 'badge-info';
    }
    
    async function generateAIAnalysis() {
      const btn = document.getElementById('generate-ai-btn');
      const loading = document.getElementById('ai-loading');
      const error = document.getElementById('ai-error');

      if (btn) btn.classList.add('hidden');
      if (loading) loading.classList.remove('hidden');
      if (error) error.classList.add('hidden');

      try {
        const response = await fetch(`${apiBase}/api/recipients/${recipientId}/ai-analysis?force_regenerate=true`);
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.detail || 'Failed to generate analysis');
        }

        if (data.narrative) {
          // Reload the page to show the new analysis
          window.location.reload();
        } else {
          throw new Error('No analysis generated');
        }
      } catch (err) {
        if (loading) loading.classList.add('hidden');
        if (btn) btn.classList.remove('hidden');
        if (error) {
          error.textContent = err.message || 'Failed to generate analysis. Please try again.';
          error.classList.remove('hidden');
        }
      }
    }

    async function loadRecipient() {
      if (!recipientId) return;
      
      try {
        const [recipientRes, awardsRes, aiRes] = await Promise.all([
          fetch(`${apiBase}/api/recipients/${recipientId}`),
          fetch(`${apiBase}/api/recipients/${recipientId}/awards?page_size=50`),
          fetch(`${apiBase}/api/recipients/${recipientId}/ai-analysis`).catch(() => null)
        ]);

        if (!recipientRes.ok) throw new Error('Recipient not found');

        const recipient = await recipientRes.json();
        const awards = await awardsRes.json();
        const aiAnalysis = aiRes?.ok ? await aiRes.json() : null;
        
        // Hide loading, show content
        document.getElementById('loading-state').classList.add('hidden');
        
        const contentDiv = document.getElementById('recipient-data');
        contentDiv.classList.remove('hidden');
        
        // Update page title
        document.title = `${recipient.name} - Ohio Fraud Tracker`;
        
        // Build nonprofit section if available
        let nonprofitSection = '';
        if (recipient.nonprofit_data) {
          const np = recipient.nonprofit_data;
          const health = np.health_indicators || {};
          const healthColor = {
            'healthy': 'green', 'fair': 'yellow', 'concerning': 'orange', 'poor': 'red'
          }[health.overall_status] || 'gray';
          
          nonprofitSection = `
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center gap-2">
                  <svg class="w-5 h-5 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 2a8 8 0 100 16 8 8 0 000-16zM5.172 5.172a6 6 0 118.656 8.656 6 6 0 01-8.656-8.656z" clip-rule="evenodd"/>
                  </svg>
                  IRS Form 990 Data
                </h3>
                <div class="flex items-center gap-2">
                  <span class="badge ${healthColor === 'green' ? 'badge-success' : healthColor === 'red' ? 'badge-danger' : 'badge-warning'}">
                    ${health.overall_status || 'unknown'} (${health.overall_score || 0}/100)
                  </span>
                  ${np.propublica_id ? `<a href="https://projects.propublica.org/nonprofits/organizations/${recipient.ein}" target="_blank" rel="noopener" class="text-xs text-primary-600 hover:underline">View on ProPublica →</a>` : ''}
                </div>
              </div>
              
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded">
                  <p class="text-xs text-gray-500 dark:text-gray-400">Total Revenue</p>
                  <p class="text-lg font-bold text-gray-900 dark:text-white">${np.financials?.total_revenue ? formatCurrency(np.financials.total_revenue) : '—'}</p>
                </div>
                <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded">
                  <p class="text-xs text-gray-500 dark:text-gray-400">Total Expenses</p>
                  <p class="text-lg font-bold text-gray-900 dark:text-white">${np.financials?.total_expenses ? formatCurrency(np.financials.total_expenses) : '—'}</p>
                </div>
                <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded">
                  <p class="text-xs text-gray-500 dark:text-gray-400">Net Assets</p>
                  <p class="text-lg font-bold text-gray-900 dark:text-white">${np.financials?.net_assets ? formatCurrency(np.financials.net_assets) : '—'}</p>
                </div>
                <div class="text-center p-3 bg-gray-50 dark:bg-gray-700 rounded">
                  <p class="text-xs text-gray-500 dark:text-gray-400">Form Type</p>
                  <p class="text-lg font-bold text-gray-900 dark:text-white">${np.form_type || '—'}</p>
                  <p class="text-xs text-gray-400">${np.tax_period ? 'FY ' + np.tax_period.slice(0,4) : ''}</p>
                </div>
              </div>
              
              ${health.indicators && health.indicators.length > 0 ? `
                <div class="border-t border-gray-200 dark:border-gray-600 pt-4">
                  <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Health Indicators</p>
                  <div class="space-y-2">
                    ${health.indicators.map(ind => `
                      <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-600 dark:text-gray-400">${ind.name}</span>
                        <span class="flex items-center gap-1">
                          <span class="w-2 h-2 rounded-full ${ind.status === 'good' ? 'bg-green-500' : ind.status === 'fair' ? 'bg-yellow-500' : 'bg-red-500'}"></span>
                          <span class="${ind.status === 'good' ? 'text-green-600 dark:text-green-400' : ind.status === 'fair' ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400'}">
                            ${ind.detail}
                          </span>
                        </span>
                      </div>
                    `).join('')}
                  </div>
                </div>
              ` : ''}
            </div>
          `;
        }
        
        // Render content
        contentDiv.innerHTML = `
          <div class="mb-6">
            <a href="/recipients" class="text-sm text-primary-600 hover:text-primary-700 dark:text-primary-400 mb-2 inline-flex items-center">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"></path>
              </svg>
              Back to Recipients
            </a>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white mt-2">${recipient.name}</h1>
            <p class="text-gray-500 dark:text-gray-400">
              ${recipient.city ? `${recipient.city}, ` : ''}${recipient.state || 'OH'}
              ${recipient.zip_code ? ` ${recipient.zip_code}` : ''}
            </p>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
              <p class="text-sm text-gray-500 dark:text-gray-400 uppercase font-medium">Total Funding</p>
              <p class="text-3xl font-bold text-green-600 dark:text-green-400 mt-2">$${formatNumber(recipient.total_amount)}</p>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
              <p class="text-sm text-gray-500 dark:text-gray-400 uppercase font-medium">Total Awards</p>
              <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2">${recipient.total_awards}</p>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
              <p class="text-sm text-gray-500 dark:text-gray-400 uppercase font-medium">Business Status</p>
              <p class="mt-2">
                <span class="badge text-lg px-3 py-1 ${recipient.business_status === 'active' ? 'badge-success' : recipient.business_status === 'unknown' ? 'badge-warning' : 'badge-danger'}">
                  ${recipient.business_status || 'unknown'}
                </span>
              </p>
            </div>
          </div>
          
          ${aiAnalysis && aiAnalysis.eligible ? `
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6 border-l-4 border-purple-500">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center gap-2">
                  <svg class="w-5 h-5 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 2a8 8 0 100 16 8 8 0 000-16zm1 12H9v-2h2v2zm0-3H9V5h2v6z"/>
                  </svg>
                  AI Risk Analysis
                  <span class="text-xs font-normal text-gray-500 dark:text-gray-400">(Powered by Claude)</span>
                </h3>
                ${aiAnalysis.narrative ? `
                  <span class="text-xs text-gray-500 dark:text-gray-400">
                    Generated ${new Date(aiAnalysis.generated_at).toLocaleDateString()}
                  </span>
                ` : `
                  <button id="generate-ai-btn" onclick="generateAIAnalysis()"
                    class="px-3 py-1.5 text-sm bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition-colors">
                    Generate Analysis
                  </button>
                `}
              </div>

              ${aiAnalysis.narrative ? `
                <div class="prose prose-sm dark:prose-invert max-w-none">
                  <div class="text-gray-700 dark:text-gray-300 whitespace-pre-wrap leading-relaxed">${aiAnalysis.narrative}</div>
                </div>
                <p class="mt-4 text-xs text-gray-400 dark:text-gray-500">
                  Risk factor: ${aiAnalysis.eligibility_reason}
                </p>
              ` : `
                <p class="text-gray-600 dark:text-gray-400 text-sm">
                  This recipient qualifies for AI analysis based on: <strong>${aiAnalysis.eligibility_reason}</strong>
                </p>
                <p class="text-gray-500 dark:text-gray-500 text-xs mt-2">
                  Click "Generate Analysis" to create a detailed risk assessment.
                </p>
              `}

              <div id="ai-loading" class="hidden mt-4">
                <div class="flex items-center gap-2 text-purple-600 dark:text-purple-400">
                  <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  <span class="text-sm">Analyzing recipient data...</span>
                </div>
              </div>

              <div id="ai-error" class="hidden mt-4 p-3 bg-red-50 dark:bg-red-900/30 rounded text-sm text-red-700 dark:text-red-300"></div>
            </div>
          ` : ''}

          ${nonprofitSection}

          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md">
            <div class="p-6 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Awards History</h3>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left">
                <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700">
                  <tr class="text-gray-600 dark:text-gray-300">
                    <th class="px-4 py-3">Agency</th>
                    <th class="px-4 py-3">Type</th>
                    <th class="px-4 py-3">Description</th>
                    <th class="px-4 py-3 text-right">Amount</th>
                    <th class="px-4 py-3 text-right">Date</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                  ${awards.items && awards.items.length > 0 ? awards.items.map(award => `
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                      <td class="px-4 py-3 font-medium text-gray-900 dark:text-white">${award.agency_code || '—'}</td>
                      <td class="px-4 py-3">
                        <span class="badge ${getBadgeClass(award.award_type || '')}">${getAwardTypeName(award.award_type)}</span>
                      </td>
                      <td class="px-4 py-3 max-w-md text-gray-600 dark:text-gray-300 truncate">
                        ${award.description ? award.description.substring(0, 80) : 'No description'}${award.description && award.description.length > 80 ? '...' : ''}
                      </td>
                      <td class="px-4 py-3 text-right font-semibold text-green-600 dark:text-green-400 whitespace-nowrap">${formatCurrency(award.amount)}</td>
                      <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400 whitespace-nowrap">${formatDate(award.award_date)}</td>
                    </tr>
                  `).join('') : `
                    <tr>
                      <td colspan="5" class="text-center py-8 text-gray-500 dark:text-gray-400">No awards found</td>
                    </tr>
                  `}
                </tbody>
              </table>
            </div>
            ${awards.total_count > 50 ? `
              <div class="p-4 border-t border-gray-200 dark:border-gray-700 text-center">
                <p class="text-sm text-gray-500 dark:text-gray-400">Showing 50 of ${awards.total_count} awards</p>
              </div>
            ` : ''}
          </div>
        `;
      } catch (err) {
        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('error-state').classList.remove('hidden');
        document.getElementById('error-message').textContent = err.message || 'Unable to load recipient.';
      }
    }
    
    loadRecipient();
  </script>
</DashboardLayout>
