            <span class="px-2 py-0.5 text-xs font-semibold bg-primary-200 dark:bg-primary-700 text-primary-800 dark:text-primary-200 rounded">START</span>
            <time class="text-sm font-normal text-gray-500 dark:text-gray-400">December 2025</time>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Project Inception</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
            Ohio Fraud Tracker launched as a transparency tool to help Ohio taxpayers track how federal funds flow into the state and identify potential fraud, waste, and abuse.
          </p>
        </div>
      </li>
    </ol>
  </div>

  <!-- Have Ideas? -->
  <div class="mt-8 bg-gradient-to-r from-primary-600 to-primary-700 rounded-lg shadow-md p-6 text-white">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <h3 class="text-lg font-semibold">Have Feature Ideas?</h3>
        <p class="text-primary-100 text-sm mt-1">We'd love to hear your suggestions for improving Ohio Fraud Tracker.</p>
      </div>
      <a href="mailto:support@ohiofraudtracker.org?subject=Feature Suggestion"
         class="inline-flex items-center gap-2 px-4 py-2 bg-white text-primary-700 font-medium rounded-lg hover:bg-primary-50 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
