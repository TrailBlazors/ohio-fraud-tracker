---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout
  title="Roadmap - Ohio Fraud Tracker"
  description="See what's been built and what's coming next for Ohio Fraud Tracker. Our timeline of features and data integrations."
  keywords="Ohio Fraud Tracker roadmap, upcoming features, development timeline"
>
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Project Roadmap</h1>
    <p class="text-gray-500 dark:text-gray-400">Where we started, where we are, and where we're going</p>
  </div>

  <!-- Stats Overview -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="flex items-center gap-3">
        <div class="p-2 bg-green-100 dark:bg-green-900/30 rounded-lg">
          <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">12</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Features Completed</p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="flex items-center gap-3">
        <div class="p-2 bg-blue-100 dark:bg-blue-900/30 rounded-lg">
          <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">3</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">In Progress</p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="flex items-center gap-3">
        <div class="p-2 bg-purple-100 dark:bg-purple-900/30 rounded-lg">
          <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"></path>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">8</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Planned Features</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Timeline -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
    <ol class="relative border-l border-gray-200 dark:border-gray-700 ml-3">

      <!-- Future: Q2 2025 -->
      <li class="mb-10 ml-6">
        <span class="absolute flex items-center justify-center w-8 h-8 bg-purple-100 rounded-full -left-4 ring-4 ring-white dark:ring-gray-800 dark:bg-purple-900">
          <svg class="w-4 h-4 text-purple-600 dark:text-purple-300" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"></path>
          </svg>
        </span>
        <div class="p-4 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded-lg">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 text-xs font-semibold bg-purple-200 dark:bg-purple-700 text-purple-800 dark:text-purple-200 rounded">PLANNED</span>
            <time class="text-sm font-normal text-gray-500 dark:text-gray-400">Q2 2025</time>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Advanced Analytics & Reporting</h3>
          <ul class="mt-2 space-y-1 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-purple-500 rounded-full"></span>
              Payment Accuracy data integration
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-purple-500 rounded-full"></span>
              Automated fraud pattern detection
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-purple-500 rounded-full"></span>
              Custom report generation
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-purple-500 rounded-full"></span>
              Public API for researchers
            </li>
          </ul>
        </div>
      </li>

      <!-- Future: Q1 2025 -->
      <li class="mb-10 ml-6">
        <span class="absolute flex items-center justify-center w-8 h-8 bg-purple-100 rounded-full -left-4 ring-4 ring-white dark:ring-gray-800 dark:bg-purple-900">
          <svg class="w-4 h-4 text-purple-600 dark:text-purple-300" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"></path>
          </svg>
        </span>
        <div class="p-4 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded-lg">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 text-xs font-semibold bg-purple-200 dark:bg-purple-700 text-purple-800 dark:text-purple-200 rounded">PLANNED</span>
            <time class="text-sm font-normal text-gray-500 dark:text-gray-400">Q1 2025</time>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Ohio State Data Integration</h3>
          <ul class="mt-2 space-y-1 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-purple-500 rounded-full"></span>
              Ohio Checkbook spending data
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-purple-500 rounded-full"></span>
              Ohio Secretary of State business filings
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-purple-500 rounded-full"></span>
              County-level mapping visualization
            </li>
          </ul>
        </div>
      </li>

      <!-- In Progress -->
      <li class="mb-10 ml-6">
        <span class="absolute flex items-center justify-center w-8 h-8 bg-blue-100 rounded-full -left-4 ring-4 ring-white dark:ring-gray-800 dark:bg-blue-900">
          <svg class="w-4 h-4 text-blue-600 dark:text-blue-300 animate-pulse" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
          </svg>
        </span>
        <div class="p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 text-xs font-semibold bg-blue-200 dark:bg-blue-700 text-blue-800 dark:text-blue-200 rounded animate-pulse">IN PROGRESS</span>
            <time class="text-sm font-normal text-gray-500 dark:text-gray-400">January 2025</time>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Community Features</h3>
          <ul class="mt-2 space-y-1 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Submit a Tip page
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Project roadmap page
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-blue-500 rounded-full animate-pulse"></span>
              Tip submission backend
            </li>
          </ul>
        </div>
      </li>

      <!-- Completed: Dec 2024 -->
      <li class="mb-10 ml-6">
        <span class="absolute flex items-center justify-center w-8 h-8 bg-green-100 rounded-full -left-4 ring-4 ring-white dark:ring-gray-800 dark:bg-green-900">
          <svg class="w-4 h-4 text-green-600 dark:text-green-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
        </span>
        <div class="p-4 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 text-xs font-semibold bg-green-200 dark:bg-green-700 text-green-800 dark:text-green-200 rounded">COMPLETED</span>
            <time class="text-sm font-normal text-gray-500 dark:text-gray-400">December 2024</time>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Performance & UI Enhancements</h3>
          <ul class="mt-2 space-y-1 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Fast mode for awards API (2-3x faster)
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              PostgreSQL full-text search
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Progressive data loading
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Funding tier colors & mega recipient animations
            </li>
          </ul>
        </div>
      </li>

      <!-- Completed: Nov 2024 -->
      <li class="mb-10 ml-6">
        <span class="absolute flex items-center justify-center w-8 h-8 bg-green-100 rounded-full -left-4 ring-4 ring-white dark:ring-gray-800 dark:bg-green-900">
          <svg class="w-4 h-4 text-green-600 dark:text-green-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
        </span>
        <div class="p-4 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 text-xs font-semibold bg-green-200 dark:bg-green-700 text-green-800 dark:text-green-200 rounded">COMPLETED</span>
            <time class="text-sm font-normal text-gray-500 dark:text-gray-400">November 2024</time>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Nonprofit IRS 990 Integration</h3>
          <ul class="mt-2 space-y-1 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              ProPublica 990 data import
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Revenue, expenses, assets display
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Recipient detail pages
            </li>
          </ul>
        </div>
      </li>

      <!-- Completed: Oct 2024 -->
      <li class="mb-10 ml-6">
        <span class="absolute flex items-center justify-center w-8 h-8 bg-green-100 rounded-full -left-4 ring-4 ring-white dark:ring-gray-800 dark:bg-green-900">
          <svg class="w-4 h-4 text-green-600 dark:text-green-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
        </span>
        <div class="p-4 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 text-xs font-semibold bg-green-200 dark:bg-green-700 text-green-800 dark:text-green-200 rounded">COMPLETED</span>
            <time class="text-sm font-normal text-gray-500 dark:text-gray-400">October 2024</time>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Production Launch</h3>
          <ul class="mt-2 space-y-1 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Migration to PostgreSQL (Neon)
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Railway deployment
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              USAspending.gov data import
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              SBA PPP loan data import
            </li>
          </ul>
        </div>
      </li>

      <!-- Project Start -->
      <li class="ml-6">
        <span class="absolute flex items-center justify-center w-8 h-8 bg-primary-100 rounded-full -left-4 ring-4 ring-white dark:ring-gray-800 dark:bg-primary-900">
          <svg class="w-4 h-4 text-primary-600 dark:text-primary-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
          </svg>
        </span>
        <div class="p-4 bg-primary-50 dark:bg-primary-900/20 border border-primary-200 dark:border-primary-800 rounded-lg">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 text-xs font-semibold bg-primary-200 dark:bg-primary-700 text-primary-800 dark:text-primary-200 rounded">START</span>
            <time class="text-sm font-normal text-gray-500 dark:text-gray-400">September 2024</time>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Project Inception</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
            Ohio Fraud Tracker started as a transparency tool to help Ohio taxpayers track how federal funds flow into the state. Built with FastAPI, Astro, and Tailwind CSS.
          </p>
        </div>
      </li>
    </ol>
  </div>

  <!-- Have Ideas? -->
  <div class="mt-8 bg-gradient-to-r from-primary-600 to-primary-700 rounded-lg shadow-md p-6 text-white">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <h3 class="text-lg font-semibold">Have Feature Ideas?</h3>
        <p class="text-primary-100 text-sm mt-1">We'd love to hear your suggestions for improving Ohio Fraud Tracker.</p>
      </div>
      <a href="mailto:support@ohiofraudtracker.org?subject=Feature Suggestion"
         class="inline-flex items-center gap-2 px-4 py-2 bg-white text-primary-700 font-medium rounded-lg hover:bg-primary-50 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        Send Suggestion
      </a>
    </div>
  </div>
</DashboardLayout>
