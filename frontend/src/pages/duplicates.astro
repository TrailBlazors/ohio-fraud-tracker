---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout 
  title="Duplicate Awards - Potential Double Payments" 
  description="Detected duplicate or near-duplicate federal awards to Ohio recipients. Same amounts, close dates - potential double billing or payment errors."
  keywords="duplicate awards Ohio, double payment fraud, government payment errors, grant fraud detection, Ohio taxpayer waste"
>
  <div class="mb-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">🔄 Duplicate Awards</h1>
        <p class="text-gray-500 dark:text-gray-400">Potential double payments or duplicate billing</p>
      </div>
      <a href="/flagged" class="text-primary-600 hover:text-primary-700 dark:text-primary-400 flex items-center gap-1 text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        All Red Flags
      </a>
    </div>
  </div>

  <!-- Error banner -->
  <div id="error-banner" class="hidden p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
    <span class="font-medium">Error:</span> <span id="error-message"></span>
  </div>

  <!-- Summary Cards -->
  <div id="summary-cards" class="hidden grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">Total Duplicates</div>
      <div id="stat-total" class="text-2xl font-bold text-gray-900 dark:text-white">0</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">Amount at Risk</div>
      <div id="stat-at-risk" class="text-2xl font-bold text-red-600 dark:text-red-400">$0</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">Critical</div>
      <div id="stat-critical" class="text-2xl font-bold text-red-600 dark:text-red-400">0</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">High Severity</div>
      <div id="stat-high" class="text-2xl font-bold text-orange-600 dark:text-orange-400">0</div>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 mb-6">
    <div class="flex flex-wrap items-center gap-3">
      <div>
        <label for="severity-filter" class="block mb-1 text-xs font-medium text-gray-700 dark:text-gray-300">Severity</label>
        <select id="severity-filter" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
          <option value="">All Severities</option>
          <option value="critical">🔴 Critical</option>
          <option value="high">🟠 High</option>
          <option value="medium">🟡 Medium</option>
          <option value="low">🟢 Low</option>
        </select>
      </div>
      <div class="flex items-end">
        <button id="filter-btn" class="px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-sm font-medium">
          Apply Filter
        </button>
      </div>
    </div>
  </div>

  <!-- Loading State -->
  <div id="loading-state" class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-8">
    <div class="flex items-center justify-center">
      <svg class="animate-spin h-8 w-8 text-primary-600" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span class="ml-2 text-gray-500">Loading duplicate awards...</span>
    </div>
  </div>

  <!-- Empty State -->
  <div id="empty-state" class="hidden bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 text-center">
    <div class="text-6xl mb-4">✅</div>
    <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">No Duplicates Found</h3>
    <p class="text-gray-500 dark:text-gray-400 mb-4">No duplicate awards have been detected. Run correlation analysis to scan for potential issues.</p>
    <a href="/" class="text-primary-600 hover:text-primary-700 dark:text-primary-400">Return to Dashboard</a>
  </div>

  <!-- Results List -->
  <div id="duplicates-list" class="hidden space-y-4"></div>

  <!-- Pagination -->
  <div id="pagination" class="hidden flex justify-center mt-6">
    <nav class="inline-flex rounded-md shadow-sm -space-x-px">
      <button id="prev-btn" class="px-4 py-2 text-sm font-medium rounded-l-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50">Previous</button>
      <span id="page-info" class="px-4 py-2 text-sm font-medium bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">Page 1</span>
      <button id="next-btn" class="px-4 py-2 text-sm font-medium rounded-r-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50">Next</button>
    </nav>
  </div>
</DashboardLayout>

<script is:inline>
  const apiBase = window.location.hostname === 'localhost' ? 'http://localhost:8000' : '';
  let currentPage = 1;
  const pageSize = 25;
  let totalItems = 0;
  
  function formatCurrency(amount) {
    if (!amount || amount === 0) return '$0';
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(amount);
  }
  
  function formatDate(dateStr) {
    if (!dateStr) return '—';
    return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }
  
  function getSeverityBadge(severity) {
    const styles = {
      critical: { bg: 'bg-red-100 dark:bg-red-900/50', text: 'text-red-800 dark:text-red-300', icon: '🔴' },
      high: { bg: 'bg-orange-100 dark:bg-orange-900/50', text: 'text-orange-800 dark:text-orange-300', icon: '🟠' },
      medium: { bg: 'bg-yellow-100 dark:bg-yellow-900/50', text: 'text-yellow-800 dark:text-yellow-300', icon: '🟡' },
      low: { bg: 'bg-green-100 dark:bg-green-900/50', text: 'text-green-800 dark:text-green-300', icon: '🟢' },
    };
    const s = styles[severity] || styles.medium;
    return `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium ${s.bg} ${s.text}">${s.icon} ${severity.toUpperCase()}</span>`;
  }
  
  function getMatchTypeBadge(matchType) {
    const styles = {
      exact: { bg: 'bg-red-100 dark:bg-red-900/50', text: 'text-red-800 dark:text-red-300', label: 'Exact Match' },
      near_exact: { bg: 'bg-orange-100 dark:bg-orange-900/50', text: 'text-orange-800 dark:text-orange-300', label: 'Near Exact' },
      similar: { bg: 'bg-blue-100 dark:bg-blue-900/50', text: 'text-blue-800 dark:text-blue-300', label: 'Similar' },
    };
    const s = styles[matchType] || styles.similar;
    return `<span class="inline-flex px-2 py-0.5 rounded text-xs font-medium ${s.bg} ${s.text}">${s.label}</span>`;
  }
  
  function getSourceBadge(source) {
    const styles = {
      usaspending: { bg: 'bg-blue-100 dark:bg-blue-900/50', text: 'text-blue-800 dark:text-blue-300', icon: '🇺🇸' },
      ohio_checkbook: { bg: 'bg-amber-100 dark:bg-amber-900/50', text: 'text-amber-800 dark:text-amber-300', icon: '🏛️' },
      sba_ppp: { bg: 'bg-green-100 dark:bg-green-900/50', text: 'text-green-800 dark:text-green-300', icon: '💼' },
    };
    const s = styles[source] || { bg: 'bg-gray-100 dark:bg-gray-700', text: 'text-gray-800 dark:text-gray-300', icon: '📄' };
    return `<span class="inline-flex px-2 py-0.5 rounded text-xs font-medium ${s.bg} ${s.text}">${s.icon}</span>`;
  }
  
  async function loadDuplicates() {
    const severityFilter = document.getElementById('severity-filter').value;
    const offset = (currentPage - 1) * pageSize;
    
    try {
      let url = `${apiBase}/api/correlation/duplicates?limit=${pageSize}&offset=${offset}`;
      if (severityFilter) url += `&severity=${severityFilter}`;
      
      const res = await fetch(url);
      if (!res.ok) throw new Error('Failed to load duplicates');
      const data = await res.json();
      
      document.getElementById('loading-state').classList.add('hidden');
      
      // Update summary cards
      document.getElementById('summary-cards').classList.remove('hidden');
      document.getElementById('stat-total').textContent = data.total.toLocaleString();
      document.getElementById('stat-at-risk').textContent = formatCurrency(data.total_at_risk);
      document.getElementById('stat-critical').textContent = (data.by_severity?.critical || 0).toLocaleString();
      document.getElementById('stat-high').textContent = (data.by_severity?.high || 0).toLocaleString();
      
      if (!data.duplicates || data.duplicates.length === 0) {
        document.getElementById('empty-state').classList.remove('hidden');
        return;
      }
      
      totalItems = data.total;
      
      // Build list
      const listEl = document.getElementById('duplicates-list');
      listEl.innerHTML = data.duplicates.map(dup => `
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
          <!-- Header -->
          <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700 flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center gap-3">
              ${getSeverityBadge(dup.severity)}
              ${getMatchTypeBadge(dup.match_type)}
              <span class="text-sm text-gray-500 dark:text-gray-400">
                ${dup.date_diff_days === 0 ? 'Same day' : dup.date_diff_days + ' days apart'}
                ${dup.amount_diff_pct > 0 ? ` • ${dup.amount_diff_pct}% amount diff` : ''}
              </span>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400">
              Flag #${dup.id}
            </div>
          </div>
          
          <!-- Recipient Info -->
          <div class="px-4 py-3 bg-gray-50 dark:bg-gray-700/50">
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium text-gray-900 dark:text-white">${dup.recipient_name || 'Unknown'}</span>
              ${dup.recipient_city ? `<span class="text-xs text-gray-500 dark:text-gray-400">• ${dup.recipient_city}</span>` : ''}
              <a href="/recipients/${dup.recipient_id}" class="text-xs text-primary-600 hover:text-primary-700 dark:text-primary-400">View Profile →</a>
            </div>
          </div>
          
          <!-- Award Comparison -->
          <div class="grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-gray-200 dark:divide-gray-700">
            <!-- Award 1 -->
            <div class="p-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Award 1</span>
                ${getSourceBadge(dup.award1?.source)}
              </div>
              <div class="text-xl font-bold text-green-600 dark:text-green-400 mb-1">
                ${formatCurrency(dup.award1?.amount)}
              </div>
              <div class="text-sm text-gray-600 dark:text-gray-300 mb-2">
                ${formatDate(dup.award1?.date)}
              </div>
              ${dup.award1?.description ? `
                <div class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2">
                  ${dup.award1.description}
                </div>
              ` : ''}
            </div>
            
            <!-- Award 2 -->
            <div class="p-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Award 2</span>
                ${getSourceBadge(dup.award2?.source)}
              </div>
              <div class="text-xl font-bold text-green-600 dark:text-green-400 mb-1">
                ${formatCurrency(dup.award2?.amount)}
              </div>
              <div class="text-sm text-gray-600 dark:text-gray-300 mb-2">
                ${formatDate(dup.award2?.date)}
              </div>
              ${dup.award2?.description ? `
                <div class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2">
                  ${dup.award2.description}
                </div>
              ` : ''}
            </div>
          </div>
          
          <!-- Actions -->
          <div class="px-4 py-3 border-t border-gray-200 dark:border-gray-700 flex justify-end gap-2">
            <button onclick="markResolved(${dup.id})" class="px-3 py-1.5 text-xs font-medium text-green-700 bg-green-100 hover:bg-green-200 dark:bg-green-900/50 dark:text-green-300 dark:hover:bg-green-900 rounded-lg transition-colors">
              ✓ Not a Duplicate
            </button>
            <button onclick="confirmDuplicate(${dup.id})" class="px-3 py-1.5 text-xs font-medium text-red-700 bg-red-100 hover:bg-red-200 dark:bg-red-900/50 dark:text-red-300 dark:hover:bg-red-900 rounded-lg transition-colors">
              🚨 Confirm Duplicate
            </button>
          </div>
        </div>
      `).join('');
      
      listEl.classList.remove('hidden');
      
      // Pagination
      const totalPages = Math.ceil(totalItems / pageSize);
      if (totalPages > 1) {
        document.getElementById('pagination').classList.remove('hidden');
        document.getElementById('page-info').textContent = `Page ${currentPage} of ${totalPages}`;
        document.getElementById('prev-btn').disabled = currentPage <= 1;
        document.getElementById('next-btn').disabled = currentPage >= totalPages;
      }
      
    } catch (err) {
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-banner').classList.remove('hidden');
      document.getElementById('error-message').textContent = err.message || 'Failed to load data';
    }
  }
  
  async function markResolved(flagId) {
    try {
      const res = await fetch(`${apiBase}/api/correlation/flags/${flagId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ is_resolved: true, notes: 'Marked as not a duplicate' })
      });
      if (res.ok) {
        loadDuplicates(); // Reload
      }
    } catch (err) {
      alert('Failed to update flag');
    }
  }
  
  async function confirmDuplicate(flagId) {
    try {
      const res = await fetch(`${apiBase}/api/correlation/flags/${flagId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ notes: 'Confirmed as duplicate - requires investigation' })
      });
      if (res.ok) {
        alert('Flagged for investigation');
        loadDuplicates();
      }
    } catch (err) {
      alert('Failed to update flag');
    }
  }
  
  function navigate(direction) {
    currentPage += direction;
    loadDuplicates();
    window.scrollTo(0, 0);
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    loadDuplicates();
    
    document.getElementById('filter-btn').addEventListener('click', () => {
      currentPage = 1;
      loadDuplicates();
    });
    
    document.getElementById('prev-btn').addEventListener('click', () => navigate(-1));
    document.getElementById('next-btn').addEventListener('click', () => navigate(1));
    
    // Filter on Enter
    document.getElementById('severity-filter').addEventListener('change', () => {
      currentPage = 1;
      loadDuplicates();
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
