---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';

// Fetch top recipients
let topRecipients = { items: [], count: 0 };
let error = null;

try {
  const response = await fetch(`${API_URL}/recipients/top?limit=20`);
  if (response.ok) {
    topRecipients = await response.json();
  } else {
    error = 'Failed to load top recipients data';
  }
} catch (e) {
  error = 'Unable to connect to API. Make sure the server is running.';
}

// Format currency
function formatCurrency(amount: number): string {
  if (amount >= 1_000_000_000) {
    return `$${(amount / 1_000_000_000).toFixed(2)}B`;
  } else if (amount >= 1_000_000) {
    return `$${(amount / 1_000_000).toFixed(2)}M`;
  } else if (amount >= 1_000) {
    return `$${(amount / 1_000).toFixed(1)}K`;
  }
  return `$${amount.toLocaleString()}`;
}

// Calculate total for context
const totalAmount = topRecipients.items.reduce((sum, r) => sum + r.total_amount, 0);
---

<DashboardLayout title="Top Recipients">
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-2">
      <span class="flex items-center justify-center w-10 h-10 rounded-lg bg-red-100 dark:bg-red-900">
        <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"></path>
        </svg>
      </span>
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Top Recipients</h1>
        <p class="text-gray-500 dark:text-gray-400">Who's getting the most federal and state money in Ohio?</p>
      </div>
    </div>
  </div>

  {error && (
    <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
      <span class="font-medium">Error:</span> {error}
    </div>
  )}

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">Top 20 Total</p>
      <p class="text-2xl font-bold text-green-600 dark:text-green-400">{formatCurrency(totalAmount)}</p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">Average per Recipient</p>
      <p class="text-2xl font-bold text-blue-600 dark:text-blue-400">
        {formatCurrency(totalAmount / Math.max(topRecipients.count, 1))}
      </p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">#1 Recipient Share</p>
      <p class="text-2xl font-bold text-amber-600 dark:text-amber-400">
        {topRecipients.items[0] ? ((topRecipients.items[0].total_amount / totalAmount) * 100).toFixed(1) : 0}%
      </p>
    </div>
  </div>

  <!-- Why This Matters -->
  <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 mb-6">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-600 dark:text-amber-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
      </svg>
      <div>
        <h3 class="font-semibold text-amber-800 dark:text-amber-200">Why This Matters</h3>
        <p class="text-sm text-amber-700 dark:text-amber-300 mt-1">
          High concentration of funds in few recipients can indicate either efficient targeting of resources 
          or potential concerns about competitive bidding and distribution equity. Click on any recipient 
          to see their full award history.
        </p>
      </div>
    </div>
  </div>

  <!-- Top Recipients Table -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700">
          <tr class="text-gray-600 dark:text-gray-300">
            <th class="px-4 py-3 w-16 text-center">Rank</th>
            <th class="px-4 py-3">Recipient</th>
            <th class="px-4 py-3 w-32">Location</th>
            <th class="px-4 py-3 w-24 text-center">Awards</th>
            <th class="px-4 py-3 w-36 text-right">Total Amount</th>
            <th class="px-4 py-3 w-28 text-right">% of Top 20</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          {topRecipients.items.map((recipient) => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-4 py-3 text-center">
                {recipient.rank <= 3 ? (
                  <span class={`inline-flex items-center justify-center w-8 h-8 rounded-full font-bold ${
                    recipient.rank === 1 ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300' :
                    recipient.rank === 2 ? 'bg-gray-100 text-gray-600 dark:bg-gray-600 dark:text-gray-200' :
                    'bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300'
                  }`}>
                    {recipient.rank}
                  </span>
                ) : (
                  <span class="text-gray-500 dark:text-gray-400">{recipient.rank}</span>
                )}
              </td>
              <td class="px-4 py-3">
                <a href={`/recipients/${recipient.id}`} class="font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300">
                  {recipient.name}
                </a>
              </td>
              <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
                {recipient.city}{recipient.state ? `, ${recipient.state}` : ''}
              </td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
                  {recipient.award_count.toLocaleString()}
                </span>
              </td>
              <td class="px-4 py-3 text-right font-semibold text-green-600 dark:text-green-400 whitespace-nowrap">
                {formatCurrency(recipient.total_amount)}
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <div class="w-16 bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                    <div 
                      class="bg-primary-600 h-2 rounded-full" 
                      style={`width: ${Math.min((recipient.total_amount / totalAmount) * 100, 100)}%`}
                    ></div>
                  </div>
                  <span class="text-gray-600 dark:text-gray-400 text-xs w-12 text-right">
                    {((recipient.total_amount / totalAmount) * 100).toFixed(1)}%
                  </span>
                </div>
              </td>
            </tr>
          ))}
          {topRecipients.items.length === 0 && !error && (
            <tr>
              <td colspan="6" class="text-center py-8 text-gray-500 dark:text-gray-400">
                No recipient data available
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Data Note -->
  <p class="mt-4 text-xs text-gray-500 dark:text-gray-400 text-center">
    Data aggregated from USAspending.gov, SBA PPP, and Ohio Checkbook. 
    Amounts reflect total awards, not necessarily disbursed funds.
  </p>
</DashboardLayout>

<style>
  :global(html.dark) table tbody td {
    color: #d1d5db !important;
  }
  :global(html.dark) table tbody td .font-medium {
    color: #ffffff !important;
  }
</style>
