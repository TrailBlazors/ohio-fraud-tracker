---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const analyses = [
  {
    href: "/red-flags/top-recipients",
    title: "Top Recipients",
    description: "Who's receiving the most federal and state funding in Ohio?",
    icon: "trophy",
    status: "live"
  },
  {
    href: "#",
    title: "Threshold Analysis",
    description: "Awards clustered just below reporting thresholds",
    icon: "chart",
    status: "coming"
  },
  {
    href: "#",
    title: "Year-End Spending",
    description: "Spending spikes at fiscal year end",
    icon: "calendar",
    status: "coming"
  },
  {
    href: "#",
    title: "No-Bid Contracts",
    description: "Awards without competitive bidding",
    icon: "document",
    status: "coming"
  },
];
---

<DashboardLayout title="Red Flags">
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-2">
      <span class="flex items-center justify-center w-10 h-10 rounded-lg bg-red-100 dark:bg-red-900">
        <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"></path>
        </svg>
      </span>
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Red Flags</h1>
        <p class="text-gray-500 dark:text-gray-400">Fraud indicators and spending pattern analysis</p>
      </div>
    </div>
  </div>

  <!-- Disclaimer -->
  <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4 mb-6">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
      </svg>
      <div>
        <h3 class="font-semibold text-blue-800 dark:text-blue-200">About These Analyses</h3>
        <p class="text-sm text-blue-700 dark:text-blue-300 mt-1">
          These tools highlight patterns that <em>may</em> warrant further investigation. 
          Appearing on these lists does not indicate wrongdoing — many legitimate reasons 
          can explain these patterns. Our goal is transparency, not accusation.
        </p>
      </div>
    </div>
  </div>

  <!-- Analysis Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {analyses.map((item) => (
      <a 
        href={item.href}
        class={`block bg-white dark:bg-gray-800 rounded-lg shadow-md p-5 border-2 transition-all ${
          item.status === 'live' 
            ? 'border-transparent hover:border-primary-500 hover:shadow-lg' 
            : 'border-transparent opacity-60 cursor-not-allowed'
        }`}
      >
        <div class="flex items-start gap-4">
          <span class={`flex items-center justify-center w-12 h-12 rounded-lg ${
            item.status === 'live' ? 'bg-primary-100 dark:bg-primary-900' : 'bg-gray-100 dark:bg-gray-700'
          }`}>
            {item.icon === 'trophy' && (
              <svg class={`w-6 h-6 ${item.status === 'live' ? 'text-primary-600 dark:text-primary-400' : 'text-gray-400'}`} fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5 5a3 3 0 013-3h4a3 3 0 013 3v1h1a2 2 0 012 2v1a5 5 0 01-5 5h-1v2h1a1 1 0 110 2H7a1 1 0 110-2h1v-2H7a5 5 0 01-5-5V8a2 2 0 012-2h1V5zm8 0H7v1h6V5zM4 8v1a3 3 0 003 3h6a3 3 0 003-3V8H4z" clip-rule="evenodd"></path>
              </svg>
            )}
            {item.icon === 'chart' && (
              <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z"></path>
                <path d="M12 2.252A8.014 8.014 0 0117.748 8H12V2.252z"></path>
              </svg>
            )}
            {item.icon === 'calendar' && (
              <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
              </svg>
            )}
            {item.icon === 'document' && (
              <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"></path>
              </svg>
            )}
          </span>
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <h3 class="font-semibold text-gray-900 dark:text-white">{item.title}</h3>
              {item.status === 'coming' && (
                <span class="px-2 py-0.5 text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 rounded">
                  Coming Soon
                </span>
              )}
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{item.description}</p>
          </div>
          {item.status === 'live' && (
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          )}
        </div>
      </a>
    ))}
  </div>

  <!-- Suggest Analysis -->
  <div class="mt-8 text-center">
    <p class="text-sm text-gray-500 dark:text-gray-400">
      Have an idea for another analysis? 
      <a href="mailto:support@ohiofraudtracker.org" class="text-primary-600 hover:text-primary-700 dark:text-primary-400">
        Let us know →
      </a>
    </p>
  </div>
</DashboardLayout>
