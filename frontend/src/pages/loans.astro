---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getLoans, formatCurrency, formatDate, formatNumber, getAwardTypeName, getAwardTypeChipClass, getAwardTypeIcon, getAgencyChipClass, getSourceName, getSourceChipClass } from '../lib/api';

const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') || '1');
const q = url.searchParams.get('q') || '';
const city = url.searchParams.get('city') || '';

let loans;
let error = null;

try {
  loans = await getLoans({ q, city, page, page_size: 25, skip_count: true });
} catch (e) {
  error = 'Unable to load loans. Make sure the API is running.';
  loans = { items: [], total_count: 0, total_pages: 0, page: 1, has_next: false, has_prev: false };
}

const baseUrl = '/loans';
const buildUrl = (newPage: number) => {
  const params = new URLSearchParams();
  if (q) params.set('q', q);
  if (city) params.set('city', city);
  params.set('page', String(newPage));
  return `${baseUrl}?${params.toString()}`;
};
---

<DashboardLayout title="Loans">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Federal Loans</h1>
    <p class="text-gray-500 dark:text-gray-400">SBA PPP, USDA, and other federal loan programs in Ohio</p>
  </div>

  {error && (
    <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
      <span class="font-medium">Error:</span> {error}
    </div>
  )}

  <!-- Search -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 mb-6">
    <form method="get" class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
      <div class="sm:col-span-1">
        <label for="q" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Search</label>
        <input type="text" id="q" name="q" value={q}
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="Business name..." />
      </div>
      
      <div class="sm:col-span-1">
        <label for="city" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">City</label>
        <input type="text" id="city" name="city" value={city}
          class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
          placeholder="e.g., Columbus, Cincinnati..." />
      </div>
      
      <div class="flex items-end sm:col-span-1">
        <button type="submit" class="w-full text-white bg-primary-600 hover:bg-primary-700 focus:ring-4 focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-primary-600 dark:hover:bg-primary-700">
          Search
        </button>
      </div>
    </form>
  </div>

  <!-- Results -->
  <div class="flex justify-between items-center mb-4">
    <p class="text-sm text-gray-500 dark:text-gray-400">
      {loans.total_count.toLocaleString()} loans found
    </p>
  </div>

  <!-- Loans Table -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left text-gray-900 dark:text-gray-300">
        <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700">
          <tr class="text-gray-600 dark:text-gray-300">
            <th class="px-4 py-3 w-[15%]">Recipient</th>
            <th class="px-4 py-3 w-24 text-center">Source / Agency</th>
            <th class="px-4 py-3 w-32 text-center">Type</th>
            <th class="px-4 py-3 w-1/4">Description</th>
            <th class="px-4 py-3 w-28 text-right">Amount</th>
            <th class="px-4 py-3 w-24 text-right">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          {loans.items.map((loan) => (
            <tr class="bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-4 py-3">
                <div class="font-medium truncate">{loan.recipient_name}</div>
                {loan.recipient_city && (
                  <div class="text-xs text-gray-500 dark:text-gray-400">{loan.recipient_city}</div>
                )}
              </td>
              <td class="px-4 py-3 text-center">
                <div class="flex flex-col items-center gap-1">
                  <span class={`inline-flex px-2 py-0.5 text-xs font-medium rounded ${getSourceChipClass(loan.source)}`} title={getSourceName(loan.source)}>
                    {loan.source === 'usaspending' ? '🇺🇸' : loan.source === 'ohio_checkbook' ? '🏛️' : loan.source === 'sba_ppp' ? '💼' : '📄'}
                  </span>
                  {loan.agency_code && (
                    <span class={`chip text-xs ${getAgencyChipClass(loan.agency_code)}`}>
                      {loan.agency_code}
                    </span>
                  )}
                </div>
              </td>
              <td class="px-4 py-3 text-center">
                <span class={`chip ${getAwardTypeChipClass(loan.award_type)}`}>
                  <span class="chip-icon">{getAwardTypeIcon(loan.award_type)}</span>
                  {getAwardTypeName(loan.award_type)}
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="truncate max-w-xs" title={loan.description || ''}>
                  {loan.description?.substring(0, 50) || '—'}{loan.description && loan.description.length > 50 ? '...' : ''}
                </div>
              </td>
              <td class="px-4 py-3 text-right font-semibold text-green-600 dark:text-green-400 whitespace-nowrap">
                {formatCurrency(loan.amount)}
              </td>
              <td class="px-4 py-3 text-right text-gray-500 dark:text-gray-400 whitespace-nowrap">
                {formatDate(loan.award_date)}
              </td>
            </tr>
          ))}
          {loans.items.length === 0 && (
            <tr>
              <td colspan="6" class="text-center py-8 text-gray-500 dark:text-gray-400">
                <div class="flex flex-col items-center">
                  <svg class="w-12 h-12 text-gray-400 mb-3" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"></path>
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"></path>
                  </svg>
                  <p class="font-medium">No loans found</p>
                  <p class="text-xs mt-1">Import SBA PPP data to see loan records</p>
                </div>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  {loans.total_pages > 1 && (
    <div class="flex justify-center mt-6">
      <nav class="inline-flex rounded-md shadow-sm -space-x-px">
        <a href={loans.has_prev ? buildUrl(page - 1) : '#'}
          class={`relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-l-lg border ${loans.has_prev ? 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-gray-300 dark:border-gray-600' : 'bg-gray-100 dark:bg-gray-900 text-gray-400 cursor-not-allowed border-gray-200 dark:border-gray-700'}`}>
          Previous
        </a>
        <span class="relative inline-flex items-center px-4 py-2 text-sm font-medium bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">
          Page {page} of {loans.total_pages}
        </span>
        <a href={loans.has_next ? buildUrl(page + 1) : '#'}
          class={`relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-r-lg border ${loans.has_next ? 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-gray-300 dark:border-gray-600' : 'bg-gray-100 dark:bg-gray-900 text-gray-400 cursor-not-allowed border-gray-200 dark:border-gray-700'}`}>
          Next
        </a>
      </nav>
    </div>
  )}
</DashboardLayout>

<style>
  /* Force dark mode text colors for this page */
  :global(html.dark) table tbody td {
    color: #d1d5db !important;
  }
  :global(html.dark) table tbody td .font-medium {
    color: #ffffff !important;
  }
  :global(html.dark) table tbody td .text-gray-500 {
    color: #9ca3af !important;
  }
</style>
