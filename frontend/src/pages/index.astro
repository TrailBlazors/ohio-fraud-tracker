---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout 
  title="Dashboard" 
  description="Track over $14 billion in federal grants, PPP loans, and government contracts flowing into Ohio. Free transparency tool to identify fraud, waste, and abuse of taxpayer funds."
  keywords="Ohio government spending, federal grants Ohio, PPP loan recipients Ohio, government contracts Ohio, taxpayer transparency, DOGE Ohio, fraud detection Ohio"
>
  <!-- Beta / Work in Progress Banner -->
  <div class="mb-4 sm:mb-6 p-3 sm:p-4 rounded-lg bg-gradient-to-r from-primary-50 to-blue-50 dark:from-primary-900/30 dark:to-blue-900/30 border border-primary-200 dark:border-primary-700">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="flex items-start gap-2 sm:gap-3">
        <div class="p-1.5 sm:p-2 bg-primary-100 dark:bg-primary-800 rounded-lg flex-shrink-0">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
          </svg>
        </div>
        <div>
          <div class="flex items-center gap-2 flex-wrap">
            <h3 class="font-semibold text-primary-800 dark:text-primary-300 text-sm sm:text-base">Work in Progress</h3>
            <span class="px-2 py-0.5 text-xs font-medium bg-primary-200 dark:bg-primary-700 text-primary-800 dark:text-primary-200 rounded-full">BETA</span>
          </div>
          <p class="text-xs sm:text-sm text-primary-700 dark:text-primary-400 mt-1">
            This transparency tool is under active development. Data imports are ongoing and fraud detection algorithms are being refined. 
            We welcome your feedback, feature requests, and bug reports!
          </p>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-2">
        <a href="mailto:support@ohiofraudtracker.org" 
           class="inline-flex items-center justify-center gap-2 px-3 sm:px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-xs sm:text-sm font-medium transition-colors whitespace-nowrap">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          Send Feedback
        </a>
      </div>
    </div>
  </div>

  <!-- Error banner (hidden by default) -->
  <div id="error-banner" class="hidden p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
    <span class="font-medium">Error:</span> <span id="error-message"></span>
  </div>

  <!-- Stats Cards (loading state) -->
  <div id="stats-loading" class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-4 sm:mb-6">
    <div class="stat-card animate-pulse">
      <div class="flex items-center">
        <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gray-300 dark:bg-gray-700 rounded-lg"></div>
        <div class="ms-3 sm:ms-4">
          <div class="h-3 w-20 bg-gray-300 dark:bg-gray-700 rounded mb-2"></div>
          <div class="h-6 w-24 bg-gray-300 dark:bg-gray-700 rounded"></div>
        </div>
      </div>
    </div>
    <div class="stat-card animate-pulse">
      <div class="flex items-center">
        <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gray-300 dark:bg-gray-700 rounded-lg"></div>
        <div class="ms-3 sm:ms-4">
          <div class="h-3 w-20 bg-gray-300 dark:bg-gray-700 rounded mb-2"></div>
          <div class="h-6 w-24 bg-gray-300 dark:bg-gray-700 rounded"></div>
        </div>
      </div>
    </div>
    <div class="stat-card animate-pulse">
      <div class="flex items-center">
        <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gray-300 dark:bg-gray-700 rounded-lg"></div>
        <div class="ms-3 sm:ms-4">
          <div class="h-3 w-20 bg-gray-300 dark:bg-gray-700 rounded mb-2"></div>
          <div class="h-6 w-24 bg-gray-300 dark:bg-gray-700 rounded"></div>
        </div>
      </div>
    </div>
    <div class="stat-card animate-pulse">
      <div class="flex items-center">
        <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gray-300 dark:bg-gray-700 rounded-lg"></div>
        <div class="ms-3 sm:ms-4">
          <div class="h-3 w-20 bg-gray-300 dark:bg-gray-700 rounded mb-2"></div>
          <div class="h-6 w-24 bg-gray-300 dark:bg-gray-700 rounded"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Cards (actual content - hidden until loaded) -->
  <div id="stats-cards" class="hidden grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-4 sm:mb-6">
    <div class="stat-card">
      <div class="flex items-center">
        <div class="inline-flex flex-shrink-0 justify-center items-center w-10 h-10 sm:w-12 sm:h-12 text-white bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg shadow-md shadow-blue-500/20">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ms-3 sm:ms-4">
          <h3 class="mb-1 text-xs sm:text-sm font-medium text-gray-500 dark:text-gray-400">Total Funding</h3>
          <p id="stat-total-amount" class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-white">$0</p>
        </div>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="flex items-center">
        <div class="inline-flex flex-shrink-0 justify-center items-center w-10 h-10 sm:w-12 sm:h-12 text-white bg-gradient-to-br from-green-500 to-green-600 rounded-lg shadow-md shadow-green-500/20">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm5 6a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V8z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ms-3 sm:ms-4">
          <h3 class="mb-1 text-xs sm:text-sm font-medium text-gray-500 dark:text-gray-400">Total Awards</h3>
          <p id="stat-total-awards" class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-white">0</p>
        </div>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="flex items-center">
        <div class="inline-flex flex-shrink-0 justify-center items-center w-10 h-10 sm:w-12 sm:h-12 text-white bg-gradient-to-br from-purple-500 to-purple-600 rounded-lg shadow-md shadow-purple-500/20">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"></path>
          </svg>
        </div>
        <div class="ms-3 sm:ms-4">
          <h3 class="mb-1 text-xs sm:text-sm font-medium text-gray-500 dark:text-gray-400">Recipients</h3>
          <p id="stat-total-recipients" class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-white">0</p>
        </div>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="flex items-center">
        <div class="inline-flex flex-shrink-0 justify-center items-center w-10 h-10 sm:w-12 sm:h-12 text-white bg-gradient-to-br from-orange-500 to-orange-600 rounded-lg shadow-md shadow-orange-500/20">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ms-3 sm:ms-4">
          <h3 class="mb-1 text-xs sm:text-sm font-medium text-gray-500 dark:text-gray-400">Agencies</h3>
          <p id="stat-total-agencies" class="text-lg sm:text-2xl font-bold text-gray-900 dark:text-white">0</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Data Sources Row -->
  <div id="data-sources" class="hidden mb-4 sm:mb-6">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white">Data Sources</h3>
      <a href="/data-status" class="text-xs sm:text-sm text-primary-600 hover:text-primary-700 dark:text-primary-400">
        View details →
      </a>
    </div>
    <div id="data-sources-grid" class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
    </div>
  </div>

  <!-- Charts Row -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4 sm:mb-6">
    <!-- Awards by Type -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 sm:p-6">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white mb-4">Awards by Type</h3>
      <div id="awards-by-type-chart">
        <div class="flex items-center justify-center py-8">
          <svg class="animate-spin h-8 w-8 text-primary-600" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="ml-2 text-gray-500">Loading chart...</span>
        </div>
      </div>
    </div>
    
    <!-- Top Agencies -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 sm:p-6">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white mb-4">Top Agencies by Funding</h3>
      <div id="top-agencies-list">
        <div class="flex items-center justify-center py-8">
          <svg class="animate-spin h-8 w-8 text-primary-600" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="ml-2 text-gray-500">Loading agencies...</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Awards Table -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md">
    <div class="p-4 sm:p-6 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white">Recent Awards</h3>
    </div>
    <div id="recent-awards-container">
      <div class="flex items-center justify-center py-12">
        <svg class="animate-spin h-8 w-8 text-primary-600" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span class="ml-2 text-gray-500">Loading recent awards...</span>
      </div>
    </div>
    <div class="p-4 border-t border-gray-200 dark:border-gray-700">
      <a href="/grants" class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300">
        View all awards →
      </a>
    </div>
  </div>
</DashboardLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script is:inline>
  // API base URL - empty string for same-origin requests in production
  const apiBase = window.location.hostname === 'localhost' ? 'http://localhost:8000' : '';
  
  // Helper functions
  function formatNumber(num) {
    if (num >= 1_000_000_000) return `${(num / 1_000_000_000).toFixed(1)}B`;
    if (num >= 1_000_000) return `${(num / 1_000_000).toFixed(1)}M`;
    if (num >= 1_000) return `${(num / 1_000).toFixed(1)}K`;
    return num.toLocaleString();
  }
  
  function formatDate(dateStr) {
    if (!dateStr) return '—';
    return new Date(dateStr).toLocaleDateString('en-US', {
      year: 'numeric', month: 'short', day: 'numeric'
    });
  }
  
  function formatCurrency(amount) {
    return new Intl.NumberFormat('en-US', {
      style: 'currency', currency: 'USD',
      minimumFractionDigits: 0, maximumFractionDigits: 0
    }).format(amount);
  }
  
  // Source config
  const sourceConfig = {
    usaspending: { 
      name: 'Federal (USAspending)', 
      icon: '🇺🇸', 
      color: 'from-blue-500 to-blue-600',
      link: '/grants?source=usaspending'
    },
    ohio_checkbook: { 
      name: 'Ohio Checkbook', 
      icon: '🏛️', 
      color: 'from-amber-500 to-amber-600',
      link: '/grants?source=ohio_checkbook'
    },
    sba_ppp: { 
      name: 'SBA PPP Loans', 
      icon: '💼', 
      color: 'from-green-500 to-green-600',
      link: '/loans'
    },
  };
  
  // Load quick stats
  async function loadStats() {
    try {
      const response = await fetch(`${apiBase}/api/stats/quick`);
      if (!response.ok) throw new Error('Failed to load stats');
      const stats = await response.json();
      
      // Update stat cards
      document.getElementById('stat-total-amount').textContent = '$' + formatNumber(stats.total_amount);
      document.getElementById('stat-total-awards').textContent = stats.total_awards.toLocaleString();
      document.getElementById('stat-total-recipients').textContent = stats.total_recipients.toLocaleString();
      document.getElementById('stat-total-agencies').textContent = (stats.total_agencies || 0).toLocaleString();
      
      // Show data sources if we have them
      if (stats.awards_by_source && Object.keys(stats.awards_by_source).length > 0) {
        const grid = document.getElementById('data-sources-grid');
        grid.innerHTML = Object.entries(stats.awards_by_source).map(([source, data]) => {
          const config = sourceConfig[source] || { name: source, icon: '📄', color: 'from-gray-500 to-gray-600', link: '/grants' };
          return `
            <a href="${config.link}" class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-3 sm:p-4 hover:shadow-lg transition-shadow">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2 sm:gap-3">
                  <div class="inline-flex flex-shrink-0 justify-center items-center w-8 h-8 sm:w-10 sm:h-10 text-white bg-gradient-to-br ${config.color} rounded-lg text-sm sm:text-lg">
                    ${config.icon}
                  </div>
                  <div>
                    <p class="font-medium text-gray-900 dark:text-white text-sm">${config.name}</p>
                    <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">${data.count.toLocaleString()} records</p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-sm sm:text-lg font-bold text-green-600 dark:text-green-400">$${formatNumber(data.total)}</p>
                </div>
              </div>
            </a>
          `;
        }).join('');
        document.getElementById('data-sources').classList.remove('hidden');
      }
      
      // Hide loading, show actual stats
      document.getElementById('stats-loading').classList.add('hidden');
      document.getElementById('stats-cards').classList.remove('hidden');
      
    } catch (err) {
      document.getElementById('error-message').textContent = 'Unable to load dashboard data. Is the API running?';
      document.getElementById('error-banner').classList.remove('hidden');
      document.getElementById('stats-loading').classList.add('hidden');
    }
  }
  
  // Load Awards by Type chart
  async function loadAwardsByType() {
    try {
      const response = await fetch(`${apiBase}/api/stats/awards-by-type`);
      const awardsData = await response.json();
      
      const chartEl = document.querySelector('#awards-by-type-chart');
      if (!Object.keys(awardsData).length) {
        chartEl.innerHTML = '<p class="text-gray-500 dark:text-gray-400 text-center py-8">No data available</p>';
        return;
      }
      
      const typeNames = {
        block_grant: 'Block Grant', formula_grant: 'Formula Grant',
        project_grant: 'Project Grant', cooperative_agreement: 'Cooperative',
        direct_loan: 'Direct Loan', guaranteed_loan: 'Guaranteed Loan',
        direct_payment: 'Direct Payment', loan: 'PPP Loan',
        contract: 'Contract', other: 'Other'
      };
      
      const labels = Object.keys(awardsData).map(type => typeNames[type] || type);
      const series = Object.values(awardsData).map(d => d.count);
      
      chartEl.innerHTML = '';
      const chart = new ApexCharts(chartEl, {
        series, labels,
        chart: { type: 'donut', height: 300 },
        colors: ['#10b981', '#34d399', '#6ee7b7', '#8b5cf6', '#3b82f6', '#0ea5e9', '#14b8a6', '#f59e0b', '#ef4444'],
        legend: { position: 'bottom', labels: { colors: '#9ca3af' } },
        plotOptions: { pie: { donut: { size: '60%' } } },
        dataLabels: { enabled: false }
      });
      chart.render();
    } catch (err) {
      document.querySelector('#awards-by-type-chart').innerHTML = 
        '<p class="text-gray-500 text-center py-8">Failed to load chart</p>';
    }
  }
  
  // Load Top Agencies
  async function loadTopAgencies() {
    try {
      const response = await fetch(`${apiBase}/api/stats/top-agencies`);
      const agencies = await response.json();
      
      const container = document.querySelector('#top-agencies-list');
      if (!agencies.length) {
        container.innerHTML = '<p class="text-gray-500 dark:text-gray-400 text-center py-4">No agency data available</p>';
        return;
      }
      
      container.innerHTML = '<div class="space-y-3">' + agencies.slice(0, 8).map(agency => `
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3 min-w-0">
            <span class="chip chip-agency">${agency.code}</span>
            <p class="text-sm text-gray-600 dark:text-gray-400 truncate">${agency.name}</p>
          </div>
          <div class="text-right flex-shrink-0 ml-4">
            <p class="text-sm font-semibold text-gray-900 dark:text-white">$${formatNumber(agency.total_amount)}</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">${agency.total_awards.toLocaleString()} awards</p>
          </div>
        </div>
      `).join('') + '</div>';
    } catch (err) {
      document.querySelector('#top-agencies-list').innerHTML = 
        '<p class="text-gray-500 text-center py-4">Failed to load agencies</p>';
    }
  }
  
  // Load Recent Awards
  async function loadRecentAwards() {
    try {
      const response = await fetch(`${apiBase}/api/stats/recent-awards`);
      const awards = await response.json();
      
      const container = document.querySelector('#recent-awards-container');
      if (!awards.length) {
        container.innerHTML = '<p class="text-center py-8 text-gray-500 dark:text-gray-400">No recent awards found</p>';
        return;
      }
      
      const sourceIcons = { usaspending: '🇺🇸', ohio_checkbook: '🏛️', sba_ppp: '💼' };
      const sourceClasses = {
        usaspending: 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300',
        ohio_checkbook: 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-300'
      };
      
      container.innerHTML = `
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700">
              <tr class="text-gray-600 dark:text-gray-300">
                <th class="px-4 py-3 w-1/3">Recipient</th>
                <th class="px-4 py-3 w-16 text-center">Source</th>
                <th class="px-4 py-3 w-20 text-center">Agency</th>
                <th class="px-4 py-3 w-28 text-right">Amount</th>
                <th class="px-4 py-3 w-28 text-right">Date</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              ${awards.map(award => `
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-900 dark:text-white truncate">${award.recipient_name}</div>
                    ${award.recipient_city ? `<div class="text-xs text-gray-500 dark:text-gray-400">${award.recipient_city}</div>` : ''}
                  </td>
                  <td class="px-4 py-3 text-center">
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded ${sourceClasses[award.source] || 'bg-gray-100 text-gray-800'}">
                      ${sourceIcons[award.source] || '📄'}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-center">
                    ${award.agency_code ? `<span class="chip chip-agency">${award.agency_code}</span>` : '<span class="text-gray-400">—</span>'}
                  </td>
                  <td class="px-4 py-3 text-right font-semibold text-green-600 dark:text-green-400 whitespace-nowrap">
                    ${formatCurrency(award.amount)}
                  </td>
                  <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400 whitespace-nowrap">
                    ${formatDate(award.award_date)}
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `;
    } catch (err) {
      document.querySelector('#recent-awards-container').innerHTML = 
        '<p class="text-center py-8 text-gray-500">Failed to load recent awards</p>';
    }
  }
  
  // Load all data on page load
  document.addEventListener('DOMContentLoaded', () => {
    loadStats();
    loadAwardsByType();
    loadTopAgencies();
    loadRecentAwards();
  });
</script>
