---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getStats, formatCurrency, formatNumber, getAwardTypeName, getAwardTypeChipClass, getAwardTypeIcon, getAgencyChipClass, formatDate } from '../lib/api';

let stats;
let error = null;

try {
  stats = await getStats();
} catch (e) {
  error = 'Unable to load dashboard data. Make sure the API is running.';
  stats = {
    total_awards: 0,
    total_amount: 0,
    total_recipients: 0,
    total_flagged: 0,
    awards_by_type: {},
    awards_by_source: {},
    top_agencies: [],
    recent_awards: [],
  };
}
---

<DashboardLayout title="Dashboard">
  <!-- Error banner -->
  {error && (
    <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
      <span class="font-medium">Error:</span> {error}
    </div>
  )}

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="stat-card">
      <div class="flex items-center">
        <div class="inline-flex flex-shrink-0 justify-center items-center w-12 h-12 text-white bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg shadow-md shadow-blue-500/20">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ms-4">
          <h3 class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Total Funding</h3>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">${formatNumber(stats.total_amount)}</p>
        </div>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="flex items-center">
        <div class="inline-flex flex-shrink-0 justify-center items-center w-12 h-12 text-white bg-gradient-to-br from-green-500 to-green-600 rounded-lg shadow-md shadow-green-500/20">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm5 6a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V8z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ms-4">
          <h3 class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Total Awards</h3>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">{stats.total_awards.toLocaleString()}</p>
        </div>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="flex items-center">
        <div class="inline-flex flex-shrink-0 justify-center items-center w-12 h-12 text-white bg-gradient-to-br from-purple-500 to-purple-600 rounded-lg shadow-md shadow-purple-500/20">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"></path>
          </svg>
        </div>
        <div class="ms-4">
          <h3 class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Recipients</h3>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">{stats.total_recipients.toLocaleString()}</p>
        </div>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="flex items-center">
        <div class="inline-flex flex-shrink-0 justify-center items-center w-12 h-12 text-white bg-gradient-to-br from-red-500 to-red-600 rounded-lg shadow-md shadow-red-500/20">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ms-4">
          <h3 class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Flagged</h3>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">{stats.total_flagged.toLocaleString()}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts Row -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <!-- Awards by Type -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Awards by Type</h3>
      <div id="awards-by-type-chart"></div>
      {Object.keys(stats.awards_by_type).length === 0 && (
        <p class="text-gray-500 dark:text-gray-400 text-center py-8">No data available</p>
      )}
    </div>
    
    <!-- Top Agencies -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Top Agencies by Funding</h3>
      <div class="space-y-3">
        {stats.top_agencies.slice(0, 8).map((agency) => (
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3 min-w-0">
              <span class={`chip ${getAgencyChipClass(agency.code)}`}>{agency.code}</span>
              <p class="text-sm text-gray-600 dark:text-gray-400 truncate">{agency.name}</p>
            </div>
            <div class="text-right flex-shrink-0 ml-4">
              <p class="text-sm font-semibold text-gray-900 dark:text-white">${formatNumber(agency.total_amount)}</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">{agency.total_awards.toLocaleString()} awards</p>
            </div>
          </div>
        ))}
        {stats.top_agencies.length === 0 && (
          <p class="text-gray-500 dark:text-gray-400 text-center py-4">No agency data available</p>
        )}
      </div>
    </div>
  </div>

  <!-- Recent Awards Table -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md">
    <div class="p-6 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Recent Awards</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700">
          <tr class="text-gray-600 dark:text-gray-300">
            <th class="px-4 py-3 w-1/3">Recipient</th>
            <th class="px-4 py-3 w-20 text-center">Agency</th>
            <th class="px-4 py-3 w-36 text-center">Type</th>
            <th class="px-4 py-3 w-28 text-right">Amount</th>
            <th class="px-4 py-3 w-28 text-right">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          {stats.recent_awards.map((award) => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900 dark:text-white truncate">{award.recipient_name}</div>
                {award.recipient_city && (
                  <div class="text-xs text-gray-500 dark:text-gray-400">{award.recipient_city}</div>
                )}
              </td>
              <td class="px-4 py-3 text-center">
                {award.agency_code ? (
                  <span class={`chip ${getAgencyChipClass(award.agency_code)}`}>
                    {award.agency_code}
                  </span>
                ) : (
                  <span class="text-gray-400">—</span>
                )}
              </td>
              <td class="px-4 py-3 text-center">
                <span class={`chip ${getAwardTypeChipClass(award.award_type)}`}>
                  <span class="chip-icon">{getAwardTypeIcon(award.award_type)}</span>
                  {getAwardTypeName(award.award_type)}
                </span>
              </td>
              <td class="px-4 py-3 text-right font-semibold text-green-600 dark:text-green-400 whitespace-nowrap">
                {formatCurrency(award.amount)}
              </td>
              <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400 whitespace-nowrap">
                {formatDate(award.award_date)}
              </td>
            </tr>
          ))}
          {stats.recent_awards.length === 0 && (
            <tr>
              <td colspan="5" class="text-center py-8 text-gray-500 dark:text-gray-400">
                No recent awards found
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
    <div class="p-4 border-t border-gray-200 dark:border-gray-700">
      <a href="/grants" class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300">
        View all awards →
      </a>
    </div>
  </div>

  <!-- ApexCharts for Awards by Type -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
  <script is:inline define:vars={{ awardsData: stats.awards_by_type }}>
    if (Object.keys(awardsData).length > 0) {
      const labels = Object.keys(awardsData).map(type => {
        const names = {
          block_grant: 'Block Grant',
          formula_grant: 'Formula Grant',
          project_grant: 'Project Grant',
          cooperative_agreement: 'Cooperative',
          direct_loan: 'Direct Loan',
          guaranteed_loan: 'Guaranteed Loan',
          direct_payment: 'Direct Payment',
          loan: 'PPP Loan',
          other: 'Other',
        };
        return names[type] || type;
      });
      
      const series = Object.values(awardsData).map(d => d.count);
      
      const options = {
        series: series,
        labels: labels,
        chart: {
          type: 'donut',
          height: 300,
        },
        colors: ['#10b981', '#34d399', '#6ee7b7', '#8b5cf6', '#3b82f6', '#0ea5e9', '#14b8a6', '#f59e0b'],
        legend: {
          position: 'bottom',
          labels: {
            colors: '#9ca3af',
          },
        },
        plotOptions: {
          pie: {
            donut: {
              size: '60%',
            },
          },
        },
        dataLabels: {
          enabled: false,
        },
        responsive: [{
          breakpoint: 480,
          options: {
            chart: {
              height: 250,
            },
            legend: {
              position: 'bottom',
            },
          },
        }],
      };

      const chart = new ApexCharts(document.querySelector("#awards-by-type-chart"), options);
      chart.render();
    }
  </script>
</DashboardLayout>
