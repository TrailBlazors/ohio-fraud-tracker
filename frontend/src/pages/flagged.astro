---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout 
  title="Flagged Recipients - Potential Fraud Indicators in Ohio" 
  description="Recipients flagged for potential fraud indicators. Inactive businesses receiving funds, unusual patterns, and other red flags in Ohio government spending."
  keywords="Ohio fraud detection, government waste Ohio, PPP fraud Ohio, grant fraud Ohio, taxpayer watchdog Ohio, government accountability"
>
  <div class="mb-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Flagged Recipients</h1>
        <p class="text-gray-500 dark:text-gray-400">Recipients with potential fraud indicators</p>
      </div>
      <a href="/" class="text-primary-600 hover:text-primary-700 dark:text-primary-400 flex items-center gap-1 text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Dashboard
      </a>
    </div>
  </div>

  <!-- Error banner (hidden) -->
  <div id="error-banner" class="hidden p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
    <span class="font-medium">Error:</span> <span id="error-message"></span>
  </div>

  <!-- Results info -->
  <p id="results-info" class="text-sm text-gray-500 dark:text-gray-400 mb-4">Loading...</p>

  <!-- Loading State -->
  <div id="loading-state" class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-8">
    <div class="flex items-center justify-center">
      <svg class="animate-spin h-8 w-8 text-primary-600" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span class="ml-2 text-gray-500">Loading flagged recipients...</span>
    </div>
  </div>

  <!-- Empty State -->
  <div id="empty-state" class="hidden bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 text-center">
    <div class="text-6xl mb-4">✅</div>
    <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">No Flagged Recipients</h3>
    <p class="text-gray-500 dark:text-gray-400">No potential issues have been detected in the current dataset.</p>
  </div>

  <!-- Flagged List -->
  <div id="flagged-list" class="hidden space-y-4"></div>

  <!-- Pagination -->
  <div id="pagination" class="hidden flex justify-center mt-6">
    <nav class="inline-flex rounded-md shadow-sm -space-x-px">
      <button id="prev-btn" class="px-4 py-2 text-sm font-medium rounded-l-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600">Previous</button>
      <span id="page-info" class="px-4 py-2 text-sm font-medium bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">Page 1</span>
      <button id="next-btn" class="px-4 py-2 text-sm font-medium rounded-r-lg border bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-600">Next</button>
    </nav>
  </div>
</DashboardLayout>

<script is:inline>
  const apiBase = window.location.hostname === 'localhost' ? 'http://localhost:8000' : '';
  let currentPage = 1;
  
  function formatCurrency(amount) {
    if (!amount || amount === 0) return '$0';
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(amount);
  }
  
  function getFlagStyle(flagType) {
    const styles = {
      inactive_business: { bg: 'bg-red-100 dark:bg-red-900/50', text: 'text-red-800 dark:text-red-400', icon: '⚠️', label: 'Inactive Business' },
      high_concentration: { bg: 'bg-orange-100 dark:bg-orange-900/50', text: 'text-orange-800 dark:text-orange-400', icon: '📊', label: 'High Concentration' },
      large_award: { bg: 'bg-purple-100 dark:bg-purple-900/50', text: 'text-purple-800 dark:text-purple-400', icon: '💰', label: 'Large Award' },
    };
    return styles[flagType] || { bg: 'bg-gray-100 dark:bg-gray-700', text: 'text-gray-800 dark:text-gray-300', icon: '🚩', label: flagType || 'Flagged' };
  }
  
  async function loadFlagged() {
    const params = new URLSearchParams(window.location.search);
    currentPage = parseInt(params.get('page') || '1');
    
    try {
      const res = await fetch(`${apiBase}/api/recipients/flagged?page=${currentPage}&page_size=25`);
      if (!res.ok) throw new Error('Failed to load flagged recipients');
      const data = await res.json();
      
      document.getElementById('loading-state').classList.add('hidden');
      
      if (!data.items || data.items.length === 0) {
        document.getElementById('empty-state').classList.remove('hidden');
        document.getElementById('results-info').textContent = 'No flagged recipients';
        return;
      }
      
      document.getElementById('results-info').textContent = `Found ${data.total_count || data.items.length} flagged recipients`;
      
      const list = document.getElementById('flagged-list');
      list.classList.remove('hidden');
      list.innerHTML = data.items.map(item => {
        const style = getFlagStyle(item.flag_type);
        // API returns: name, city, business_status, flag_reason, flag_type, total_amount, total_awards
        return `
          <a href="/recipients/${item.id}" class="block bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 sm:p-6 border-l-4 border-red-500 hover:shadow-lg transition-shadow">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
              <div class="flex-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white">${item.name || 'Unknown Recipient'}</h3>
                  <span class="px-2 py-0.5 rounded text-xs font-medium ${style.bg} ${style.text}">
                    ${style.icon} ${style.label}
                  </span>
                </div>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                  ${item.city || 'Ohio'} • Status: ${item.business_status || 'unknown'}
                </p>
                ${item.flag_reason ? `<p class="text-sm text-gray-600 dark:text-gray-300 mt-2">${item.flag_reason}</p>` : ''}
              </div>
              <div class="text-right flex-shrink-0">
                <p class="text-xl font-bold text-green-600 dark:text-green-400">${formatCurrency(item.total_amount)}</p>
                <p class="text-sm text-gray-500">total funding</p>
              </div>
            </div>
          </a>
        `;
      }).join('');
      
      const pagination = document.getElementById('pagination');
      if (data.has_next || data.has_prev) {
        pagination.classList.remove('hidden');
        document.getElementById('page-info').textContent = `Page ${currentPage}`;
        document.getElementById('prev-btn').disabled = !data.has_prev;
        document.getElementById('next-btn').disabled = !data.has_next;
        document.getElementById('prev-btn').classList.toggle('opacity-50', !data.has_prev);
        document.getElementById('next-btn').classList.toggle('opacity-50', !data.has_next);
      }
    } catch (err) {
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-banner').classList.remove('hidden');
      document.getElementById('error-message').textContent = err.message;
    }
  }
  
  function navigate(newPage) {
    const params = new URLSearchParams(window.location.search);
    params.set('page', String(newPage));
    window.location.search = params.toString();
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    loadFlagged();
    document.getElementById('prev-btn').addEventListener('click', () => navigate(currentPage - 1));
    document.getElementById('next-btn').addEventListener('click', () => navigate(currentPage + 1));
  });
</script>
