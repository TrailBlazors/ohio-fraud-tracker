---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getFlaggedRecipients, formatCurrency, formatNumber } from '../lib/api';

const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') || '1');

let flagged;
let error = null;

try {
  flagged = await getFlaggedRecipients({ page, page_size: 25 });
} catch (e) {
  error = 'Unable to load flagged recipients. Make sure the API is running.';
  flagged = { items: [], total_count: 0, total_pages: 0, page: 1, has_next: false, has_prev: false };
}

// Helper to get flag type styling
function getFlagTypeStyle(flagType: string) {
  const styles = {
    inactive_business: { bg: 'bg-red-100 dark:bg-red-900/50', text: 'text-red-800 dark:text-red-400', icon: '⚠️', label: 'Inactive Business' },
    high_concentration: { bg: 'bg-orange-100 dark:bg-orange-900/50', text: 'text-orange-800 dark:text-orange-400', icon: '📊', label: 'High Concentration' },
    large_award: { bg: 'bg-purple-100 dark:bg-purple-900/50', text: 'text-purple-800 dark:text-purple-400', icon: '💰', label: 'Large Award' },
  };
  return styles[flagType] || { bg: 'bg-gray-100 dark:bg-gray-700', text: 'text-gray-800 dark:text-gray-300', icon: '🚩', label: 'Flagged' };
}
---

<DashboardLayout title="Flagged Recipients">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">🚩 Flagged Recipients</h1>
    <p class="text-gray-500 dark:text-gray-400">Recipients with potential issues requiring review</p>
  </div>

  {error && (
    <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900 dark:text-red-300" role="alert">
      <span class="font-medium">Error:</span> {error}
    </div>
  )}

  <!-- Info banner -->
  <div class="p-3 sm:p-4 mb-6 rounded-lg bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800">
    <div class="flex items-center text-blue-800 dark:text-blue-300 mb-3">
      <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
      </svg>
      <span class="font-medium">What gets flagged:</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
      <div class="flex items-start gap-2 sm:gap-3 p-2 sm:p-3 bg-white/50 dark:bg-gray-800/50 rounded-lg">
        <span class="inline-flex items-center justify-center w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-red-100 dark:bg-red-900/50 text-red-600 dark:text-red-400 flex-shrink-0 text-sm">
          ⚠️
        </span>
        <div>
          <p class="font-medium text-gray-900 dark:text-white text-sm">Inactive Business</p>
          <p class="text-xs text-gray-600 dark:text-gray-400">Businesses with inactive/dissolved status receiving federal funds</p>
        </div>
      </div>
      <div class="flex items-start gap-2 sm:gap-3 p-2 sm:p-3 bg-white/50 dark:bg-gray-800/50 rounded-lg">
        <span class="inline-flex items-center justify-center w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-orange-100 dark:bg-orange-900/50 text-orange-600 dark:text-orange-400 flex-shrink-0 text-sm">
          📊
        </span>
        <div>
          <p class="font-medium text-gray-900 dark:text-white text-sm">High Concentration</p>
          <p class="text-xs text-gray-600 dark:text-gray-400">Unusually high number of awards (20+ awards)</p>
        </div>
      </div>
      <div class="flex items-start gap-2 sm:gap-3 p-2 sm:p-3 bg-white/50 dark:bg-gray-800/50 rounded-lg">
        <span class="inline-flex items-center justify-center w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-purple-100 dark:bg-purple-900/50 text-purple-600 dark:text-purple-400 flex-shrink-0 text-sm">
          💰
        </span>
        <div>
          <p class="font-medium text-gray-900 dark:text-white text-sm">Large Award</p>
          <p class="text-xs text-gray-600 dark:text-gray-400">Single awards over $50 million (requires verification)</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div class="flex justify-between items-center mb-4">
    <p class="text-sm text-gray-500 dark:text-gray-400">
      {flagged.total_count} potential issue{flagged.total_count !== 1 ? 's' : ''} found
    </p>
  </div>

  <!-- Flagged Table -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
    <!-- Mobile Card View -->
    <div class="sm:hidden divide-y divide-gray-200 dark:divide-gray-700">
      {flagged.items.map((item) => {
        const flagStyle = getFlagTypeStyle(item.flag_type);
        return (
          <a href={`/recipients/${item.id}`} class="block p-4 hover:bg-gray-50 dark:hover:bg-gray-700">
            <div class="flex justify-between items-start mb-2">
              <span class="font-medium text-gray-900 dark:text-white text-sm truncate flex-1 mr-2">{item.name}</span>
              <span class="font-semibold text-red-600 dark:text-red-400 whitespace-nowrap">
                {formatCurrency(item.total_amount)}
              </span>
            </div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium ${flagStyle.bg} ${flagStyle.text}`}>
                <span>{flagStyle.icon}</span>
                <span>{flagStyle.label}</span>
              </span>
              <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${item.business_status === 'unknown' ? 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400' : 'bg-red-100 text-red-800 dark:bg-red-900/50 dark:text-red-400'}`}>
                {item.business_status}
              </span>
            </div>
            <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2">{item.flag_reason}</p>
            <div class="flex justify-between mt-2 text-xs text-gray-500 dark:text-gray-400">
              <span>{item.city || 'Ohio'}</span>
              <span>{item.total_awards} awards</span>
            </div>
          </a>
        );
      })}
      {flagged.items.length === 0 && !error && (
        <div class="p-8 text-center">
          <svg class="w-12 h-12 text-green-500 mx-auto mb-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          <p class="font-medium text-gray-900 dark:text-white">No flagged recipients</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">All recipients appear normal</p>
        </div>
      )}
    </div>
    
    <!-- Desktop Table View -->
    <div class="hidden sm:block overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-700">
          <tr class="text-gray-600 dark:text-gray-300">
            <th class="px-4 py-3 w-1/4">Recipient</th>
            <th class="px-4 py-3 w-32 text-center">Flag Type</th>
            <th class="px-4 py-3 w-24 text-center">Status</th>
            <th class="px-4 py-3 w-20 text-center">Awards</th>
            <th class="px-4 py-3 w-28 text-right">Amount</th>
            <th class="px-4 py-3">Reason</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          {flagged.items.map((item) => {
            const flagStyle = getFlagTypeStyle(item.flag_type);
            return (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-4 py-3">
                  <a href={`/recipients/${item.id}`} class="font-medium text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400">
                    {item.name}
                  </a>
                  <div class="text-xs text-gray-500 dark:text-gray-400">{item.city || 'Ohio'}</div>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium ${flagStyle.bg} ${flagStyle.text}`}>
                    <span>{flagStyle.icon}</span>
                    <span>{flagStyle.label}</span>
                  </span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${item.business_status === 'unknown' ? 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400' : 'bg-red-100 text-red-800 dark:bg-red-900/50 dark:text-red-400'}`}>
                    {item.business_status}
                  </span>
                </td>
                <td class="px-4 py-3 text-center font-medium text-gray-700 dark:text-gray-300">{item.total_awards}</td>
                <td class="px-4 py-3 text-right font-semibold text-red-600 dark:text-red-400 whitespace-nowrap">
                  {formatCurrency(item.total_amount)}
                </td>
                <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                  {item.flag_reason}
                </td>
              </tr>
            );
          })}
          {flagged.items.length === 0 && !error && (
            <tr>
              <td colspan="6" class="text-center py-12 text-gray-500 dark:text-gray-400">
                <div class="flex flex-col items-center">
                  <svg class="w-16 h-16 text-green-500 mb-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <p class="font-medium text-lg">No flagged recipients found</p>
                  <p class="text-sm mt-1">All recipients appear normal based on current detection criteria</p>
                  <div class="mt-4 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg text-left max-w-md">
                    <p class="text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">Future detection will improve when:</p>
                    <ul class="text-xs text-gray-600 dark:text-gray-400 space-y-1">
                      <li>• Ohio SOS business registry data is imported</li>
                      <li>• More recipients accumulate 20+ awards</li>
                      <li>• Large single awards ($50M+) are detected</li>
                    </ul>
                  </div>
                </div>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  {flagged.total_pages > 1 && (
    <div class="flex justify-center mt-6">
      <nav class="inline-flex rounded-md shadow-sm -space-x-px">
        <a href={flagged.has_prev ? `?page=${page - 1}` : '#'}
          class={`relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-l-lg border ${flagged.has_prev ? 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-gray-300 dark:border-gray-600' : 'bg-gray-100 dark:bg-gray-900 text-gray-400 cursor-not-allowed border-gray-200 dark:border-gray-700'}`}>
          Previous
        </a>
        <span class="relative inline-flex items-center px-4 py-2 text-sm font-medium bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">
          Page {page} of {flagged.total_pages}
        </span>
        <a href={flagged.has_next ? `?page=${page + 1}` : '#'}
          class={`relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-r-lg border ${flagged.has_next ? 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-gray-300 dark:border-gray-600' : 'bg-gray-100 dark:bg-gray-900 text-gray-400 cursor-not-allowed border-gray-200 dark:border-gray-700'}`}>
          Next
        </a>
      </nav>
    </div>
  )}
</DashboardLayout>
