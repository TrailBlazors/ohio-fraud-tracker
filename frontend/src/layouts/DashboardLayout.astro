---
export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
}

const { 
  title, 
  description = "Track billions in federal grants, loans, and contracts flowing into Ohio. A free transparency tool helping taxpayers identify potential fraud, waste, and abuse of public funds.",
  keywords = "Ohio fraud, government grants Ohio, federal funding Ohio, PPP loan fraud Ohio, government waste, taxpayer transparency, Ohio contracts, USAspending Ohio, government accountability",
  ogImage = "/og-image.png"
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, "https://ohiofraudtracker.org").toString();
const fullTitle = title === "Dashboard" ? "Ohio Fraud Tracker - Track Federal Grants & Government Spending in Ohio" : `${title} | Ohio Fraud Tracker`;

const navItems = [
  { href: "/", label: "Dashboard", icon: "chart-pie" },
  { href: "/grants", label: "Grants", icon: "gift" },
  { href: "/loans", label: "PPP Loans", icon: "currency-dollar" },
  { href: "/recipients", label: "Recipients", icon: "users" },
  { href: "/politicians", label: "Politicians", icon: "user-group" },
  { href: "/campaign-finance", label: "Campaign Finance", icon: "banknotes" },
  { href: "/data-status", label: "Data Status", icon: "database" },
];

// Red Flags submenu items
const redFlagsItems = [
  { href: "/duplicates", label: "Duplicate Awards", icon: "duplicate" },
  { href: "/red-flags/top-recipients", label: "Top Recipients", icon: "trophy" },
  { href: "/red-flags/funding-before-formation", label: "Pre-Formation Funding", icon: "calendar-x" },
  { href: "/red-flags/political-donors", label: "Political Donors", icon: "banknotes" },
  { href: "/red-flags/excluded-entities", label: "Excluded Entities", icon: "ban" },
];

// Check if current path is in red flags section
const isRedFlagsSection = Astro.url.pathname.startsWith('/red-flags') || Astro.url.pathname.startsWith('/duplicates');

// Helper to format source info
function getSourceInfo(sourceKey: string) {
  return null;
}

// WebSite schema (enables Google Sitelinks Searchbox)
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Ohio Fraud Tracker",
  "alternateName": "OFT",
  "url": "https://ohiofraudtracker.org",
  "description": "A free transparency tool tracking federal grants, loans, and contracts flowing into Ohio to help taxpayers identify potential fraud, waste, and abuse of public funds.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://ohiofraudtracker.org/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

// Organization schema (drives Google's knowledge panel / rich listing)
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Ohio Fraud Tracker",
  "alternateName": "OFT",
  "url": "https://ohiofraudtracker.org",
  "logo": {
    "@type": "ImageObject",
    "url": "https://ohiofraudtracker.org/og-image.png",
    "width": 1200,
    "height": 630
  },
  "description": "Ohio Fraud Tracker is a free public transparency tool that tracks billions in federal grants, PPP loans, and government contracts flowing into Ohio — helping taxpayers identify potential fraud, waste, and abuse of public funds.",
  "foundingDate": "2024",
  "areaServed": {
    "@type": "State",
    "name": "Ohio",
    "sameAs": "https://www.wikidata.org/wiki/Q1397"
  },
  "knowsAbout": [
    "Government transparency",
    "Federal grant tracking",
    "Medicare fraud",
    "Medicaid fraud",
    "PPP loan fraud",
    "Ohio government spending",
    "Taxpayer accountability"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer support",
    "email": "support@ohiofraudtracker.org"
  }
};

// Breadcrumb schema for nested pages
const breadcrumbItems: { name: string; url: string }[] = [
  { name: "Ohio Fraud Tracker", url: "https://ohiofraudtracker.org/" }
];
if (isRedFlagsSection) {
  breadcrumbItems.push({ name: "Red Flags", url: "https://ohiofraudtracker.org/red-flags" });
}
if (title !== "Dashboard") {
  breadcrumbItems.push({ name: title, url: canonicalURL });
}
const breadcrumbSchema = breadcrumbItems.length > 1 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": item.url
  }))
} : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- Primary Meta Tags -->
  <title>{fullTitle}</title>
  <meta name="title" content={fullTitle} />
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="author" content="Ohio Fraud Tracker" />
  <meta name="robots" content="index, follow" />
  <meta name="msvalidate.01" content="A790B030A081DAEF72DEEE8B1DF5C4CB" />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://ohiofraudtracker.org/og-image.png" />
  <meta property="og:site_name" content="Ohio Fraud Tracker" />
  <meta property="og:locale" content="en_US" />
  
  <!-- X (Twitter) Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://ohiofraudtracker.org/og-image.png" />
  <meta name="twitter:image:alt" content="Ohio Fraud Tracker - Federal funding transparency tool" />
  
  <!-- Geo Tags for Ohio -->
  <meta name="geo.region" content="US-OH" />
  <meta name="geo.placename" content="Ohio" />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  
  <style>
    /* Force dark mode table text colors - aggressive override */
    html.dark table tbody td {
      color: #d1d5db !important;
    }
    html.dark table tbody td * {
      color: inherit !important;
    }
    html.dark table tbody td [class*="font-medium"],
    html.dark table tbody td [class*="font-semibold"],
    html.dark table tbody td [class*="font-bold"],
    html.dark table tbody td [class*="text-gray-900"] {
      color: #ffffff !important;
    }
    html.dark table tbody td [class*="text-green"] {
      color: #4ade80 !important;
    }
    html.dark table tbody td [class*="text-gray-5"],
    html.dark table tbody td [class*="text-gray-4"],
    html.dark table tbody td [class*="text-gray-6"] {
      color: #9ca3af !important;
    }
  </style>
  <script is:inline>
    // Default to light mode unless explicitly set to dark
    if (localStorage.getItem('color-theme') === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
  
  <!-- Google Analytics -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-3YVG53SZJJ"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-3YVG53SZJJ');
  </script>
</head>
