                  <path fill-rule="evenodd" d="M1 4a1 1 0 011-1h16a1 1 0 011 1v8a1 1 0 01-1 1H2a1 1 0 01-1-1V4zm12 4a3 3 0 11-6 0 3 3 0 016 0zM4 9a1 1 0 100-2 1 1 0 000 2zm13-1a1 1 0 11-2 0 1 1 0 012 0zM1.75 14.5a.75.75 0 000 1.5c4.417 0 8.693.603 12.749 1.73 1.111.309 2.251-.512 2.251-1.696v-.784a.75.75 0 00-1.5 0v.784a.272.272 0 01-.35.25A49.043 49.043 0 001.75 14.5z" clip-rule="evenodd"></path>
                </svg>
              )}
              <span class="ms-3">{item.label}</span>
            </a>
          </li>
        ))}
        
        <!-- Red Flags Section -->
        <li>
          <button type="button" id="red-flags-toggle" class={`flex items-center w-full p-2 text-base transition duration-75 rounded-lg group ${isRedFlagsSection ? 'bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-300' : 'text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700'}`} aria-controls="dropdown-red-flags">
            <svg class="w-5 h-5 transition duration-75 text-red-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"></path>
            </svg>
            <span class="flex-1 ms-3 text-left whitespace-nowrap">Red Flags</span>
            <svg id="red-flags-chevron" class={`w-3 h-3 transition-transform ${isRedFlagsSection ? 'rotate-180' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 10 6" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
            </svg>
          </button>
          <ul id="dropdown-red-flags" class={`${isRedFlagsSection ? '' : 'hidden'} py-2 space-y-2`}>
            {redFlagsItems.map((item) => (
              <li>
                <a href={item.href} class={`flex items-center w-full p-2 pl-11 transition duration-75 rounded-lg group ${currentPath === item.href ? 'bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-300' : 'text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700'}`}>
                  {item.icon === 'duplicate' && (
                    <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M7 9a2 2 0 012-2h6a2 2 0 012 2v6a2 2 0 01-2 2H9a2 2 0 01-2-2V9z"></path>
                      <path d="M5 3a2 2 0 00-2 2v6a2 2 0 002 2V5h8a2 2 0 00-2-2H5z"></path>
                    </svg>
                  )}
                  {item.icon === 'trophy' && (
                    <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M5 5a3 3 0 013-3h4a3 3 0 013 3v1h1a2 2 0 012 2v1a5 5 0 01-5 5h-1v2h1a1 1 0 110 2H7a1 1 0 110-2h1v-2H7a5 5 0 01-5-5V8a2 2 0 012-2h1V5zm8 0H7v1h6V5zM4 8v1a3 3 0 003 3h6a3 3 0 003-3V8H4z" clip-rule="evenodd"></path>
