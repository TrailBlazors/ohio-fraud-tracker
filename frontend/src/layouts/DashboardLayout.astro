            <!-- Ohio flag (burgee/swallowtail shape) -->
            <svg class="w-12 h-7" viewBox="0 0 143 95" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Ohio Flag">
              <defs>
                <clipPath id="swallowtail">
                  <polygon points="0,0 105,0 143,47.5 105,95 0,95"/>
